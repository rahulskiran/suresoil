{% comment %}Video Carousel Section - sections/VideoCarousel.liquid{% endcomment %}

{%- liquid
  assign s_id = section.id
-%}

<section class="vc" id="vc-{{ s_id }}">
  <div class="vc__container">
    <div class="vc__header">
      <span class="vc__eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="vc__title">{{ section.settings.heading }}</h2>
      <p class="vc__subtitle">{{ section.settings.subheading }}</p>
    </div>

    <div class="vc__track-wrap">
      <button class="vc__nav-btn vc__nav-btn--prev" type="button" data-vc-nav="left" aria-label="Scroll videos left">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M14.5 5.5L8 12l6.5 6.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="vc__track" data-vc-track>
        {%- for block in section.blocks -%}
          <article class="vc__card" {{ block.shopify_attributes }}>
            <a class="vc__media-wrap" href="{{ block.settings.video_url | default: '#' }}">
              <div class="vc__media">
                {%- if block.settings.thumbnail != blank -%}
                  {{ block.settings.thumbnail
                    | image_url: width: 900
                    | image_tag:
                      class: 'vc__thumb',
                      loading: 'lazy',
                      widths: '360,540,720,900',
                      sizes: '(max-width: 767px) 240px, (max-width: 991px) 280px, 300px',
                      alt: block.settings.title
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'vc__thumb vc__thumb--placeholder' }}
                {%- endif -%}

                <div class="vc__gradient"></div>

                <span class="vc__play" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="M8 5.5l10 6.5-10 6.5V5.5z" fill="currentColor"/>
                  </svg>
                </span>

                <span class="vc__duration" aria-label="Video duration">
                  {{ block.settings.duration }}
                </span>
              </div>
            </a>

            <div class="vc__content">
              <h3 class="vc__card-title">{{ block.settings.title }}</h3>
            </div>
          </article>
        {%- endfor -%}
      </div>

      <button class="vc__nav-btn vc__nav-btn--next" type="button" data-vc-nav="right" aria-label="Scroll videos right">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9.5 5.5L16 12l-6.5 6.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  #vc-{{ s_id }} {
    --vc-bg: #ffffff;
    --vc-heading: #14532d;
    --vc-text: #6b7280;
    --vc-accent: #16a34a;
    --vc-card-bg: #f9fafb;
    --vc-border: #e5e7eb;
    --vc-card-title: #1f2937;
    --vc-eyebrow-bg: #efe7b0;
    --vc-eyebrow-txt: #a16207;
  }

  #vc-{{ s_id }}.vc {
    background: var(--vc-bg);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  #vc-{{ s_id }} .vc__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 {{ section.settings.padding_horizontal }}px;
  }

  #vc-{{ s_id }} .vc__header {
    text-align: center;
    margin-bottom: 40px;
  }

  #vc-{{ s_id }} .vc__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    width: fit-content;
    padding: 5px 14px;
    border-radius: 999px;
    background: var(--vc-eyebrow-bg);
    color: var(--vc-eyebrow-txt);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: 12px;
  }

  #vc-{{ s_id }} .vc__title {
    margin: 0 auto 14px;
    color: var(--vc-heading);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    font-size: clamp(1.75rem, 3.8vw, 2.5rem);
    max-width: 600px;
    text-wrap: balance;
  }

  #vc-{{ s_id }} .vc__subtitle {
    margin: 0 auto;
    color: var(--vc-text);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 480px;
  }

  #vc-{{ s_id }} .vc__track-wrap {
    position: relative;
  }

  #vc-{{ s_id }} .vc__nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid var(--vc-border);
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(6px);
    color: var(--vc-card-title);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  #vc-{{ s_id }} .vc__nav-btn:hover {
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.1);
    transform: translateY(-50%) scale(1.05);
  }

  #vc-{{ s_id }} .vc__nav-btn--prev { left: -20px; }
  #vc-{{ s_id }} .vc__nav-btn--next { right: -20px; }

  #vc-{{ s_id }} .vc__nav-btn svg {
    width: 18px;
    height: 18px;
  }

  #vc-{{ s_id }} .vc__track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding: 4px 0 8px;
    -ms-overflow-style: none;
    scrollbar-width: none;
    justify-content: center;
  }

  #vc-{{ s_id }} .vc__track::-webkit-scrollbar {
    display: none;
  }

  #vc-{{ s_id }} .vc__card {
    flex: 0 0 auto;
    width: 220px;
    scroll-snap-align: center;
  }

  #vc-{{ s_id }} .vc__media-wrap {
    display: block;
    text-decoration: none;
    margin-bottom: 10px;
  }

  #vc-{{ s_id }} .vc__media {
    position: relative;
    overflow: hidden;
    border-radius: 14px;
    aspect-ratio: 9 / 16;
    background: #f3f4f6;
  }

  #vc-{{ s_id }} .vc__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  #vc-{{ s_id }} .vc__thumb--placeholder {
    opacity: 0.4;
  }

  #vc-{{ s_id }} .vc__media:hover .vc__thumb {
    transform: scale(1.04);
  }

  #vc-{{ s_id }} .vc__gradient {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.15) 35%, transparent 60%);
  }

  #vc-{{ s_id }} .vc__play {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 52px;
    height: 52px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.25s ease, transform 0.25s ease;
    z-index: 2;
  }

  #vc-{{ s_id }} .vc__play svg {
    width: 22px;
    height: 22px;
    margin-left: 2px;
  }

  #vc-{{ s_id }} .vc__media:hover .vc__play {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.05);
  }

  #vc-{{ s_id }} .vc__duration {
    position: absolute;
    right: 10px;
    bottom: 10px;
    border-radius: 6px;
    padding: 3px 7px;
    font-size: 11px;
    font-weight: 500;
    color: #ffffff;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    z-index: 2;
  }

  #vc-{{ s_id }} .vc__content {
    text-align: center;
    padding: 0 4px;
  }

  #vc-{{ s_id }} .vc__card-title {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.35;
    color: var(--vc-card-title);
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
  }

  @media screen and (min-width: 768px) {
    #vc-{{ s_id }} .vc__card {
      width: 240px;
    }
  }

  @media screen and (min-width: 992px) {
    #vc-{{ s_id }} .vc__card {
      width: 260px;
    }
  }

  @media screen and (max-width: 767px) {
    #vc-{{ s_id }} .vc__header {
      margin-bottom: 28px;
    }

    #vc-{{ s_id }} .vc__eyebrow {
      font-size: 10px;
      padding: 4px 12px;
      letter-spacing: 0.1em;
    }

    #vc-{{ s_id }} .vc__subtitle {
      font-size: 0.9rem;
    }

    #vc-{{ s_id }} .vc__track {
      justify-content: flex-start;
    }

    #vc-{{ s_id }} .vc__nav-btn {
      display: none;
    }
  }
</style>

<script>
  (function () {
    function initVideoCarousel(sectionId) {
      var section = document.getElementById('vc-' + sectionId);
      if (!section) return;

      // Ref-like container handle for smooth horizontal scrolling.
      var trackRef = section.querySelector('[data-vc-track]');
      if (!trackRef) return;

      var scrollByAmount = 400;
      var leftBtn = section.querySelector('[data-vc-nav="left"]');
      var rightBtn = section.querySelector('[data-vc-nav="right"]');

      if (leftBtn && !leftBtn.dataset.bound) {
        leftBtn.dataset.bound = 'true';
        leftBtn.addEventListener('click', function () {
          trackRef.scrollBy({ left: -scrollByAmount, behavior: 'smooth' });
        });
      }

      if (rightBtn && !rightBtn.dataset.bound) {
        rightBtn.dataset.bound = 'true';
        rightBtn.addEventListener('click', function () {
          trackRef.scrollBy({ left: scrollByAmount, behavior: 'smooth' });
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initVideoCarousel('{{ s_id }}');
      });
    } else {
      initVideoCarousel('{{ s_id }}');
    }

    document.addEventListener('shopify:section:load', function (event) {
      if (event.detail && event.detail.sectionId === '{{ s_id }}') {
        initVideoCarousel('{{ s_id }}');
      }
    });
  })();
</script>

