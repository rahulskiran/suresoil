{% comment %}Applications Bento Grid — sections/Applications.liquid{% endcomment %}

{%- liquid
  assign s_id = section.id
  assign cards = section.blocks | where: 'type', 'card'
-%}

<section class="ab" id="ab-{{ s_id }}">
  <div class="ab__wrap">

    {%- comment -%}── Header ──{%- endcomment -%}
    <div class="ab__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="ab__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="ab__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="ab__sub">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    {%- comment -%}── Bento Grid ──{%- endcomment -%}
    <div class="ab__grid">

      {%- comment -%}── Corner cards (positions 1–4) ──{%- endcomment -%}
      {%- for block in cards -%}
        {%- case forloop.index -%}
          {%- when 1 -%}{%- assign pos = 'tl' -%}
          {%- when 2 -%}{%- assign pos = 'tr' -%}
          {%- when 3 -%}{%- assign pos = 'bl' -%}
          {%- when 4 -%}{%- assign pos = 'br' -%}
        {%- endcase -%}
        <div class="ab__card ab__card--{{ pos }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{- block.settings.image
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  widths: '400,600,800',
                  sizes: '(max-width: 767px) 50vw, 25vw',
                  class: 'ab__card-img',
                  alt: block.settings.title
            -}}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'ab__card-img ab__card-img--ph' }}
          {%- endif -%}
          <div class="ab__card-overlay ab__card-overlay--{{ pos }}"></div>
          <div class="ab__card-content">
            {%- if block.settings.title != blank -%}
              <h3 class="ab__card-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="ab__card-text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}

      {%- comment -%}── Center hero card ──{%- endcomment -%}
      <div class="ab__hero">
        {%- if section.settings.hero_image != blank -%}
          {{- section.settings.hero_image
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                widths: '600,800,1000,1200',
                sizes: '(max-width: 767px) 100vw, 50vw',
                class: 'ab__hero-img',
                alt: section.settings.hero_heading
          -}}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'ab__hero-img ab__hero-img--ph' }}
        {%- endif -%}
        <div class="ab__hero-overlay"></div>
        <div class="ab__hero-content">
          {%- if section.settings.hero_badge != blank -%}
            <span class="ab__hero-badge">{{ section.settings.hero_badge }}</span>
          {%- endif -%}
          {%- if section.settings.hero_heading != blank -%}
            <p class="ab__hero-text">{{ section.settings.hero_heading }}</p>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
#ab-{{ s_id }}{
  --ab-bg:{{ section.settings.bg_color }};
  --ab-heading:{{ section.settings.heading_color }};
  --ab-sub:{{ section.settings.subtext_color }};
  --ab-accent:{{ section.settings.accent_color }};
  --ab-card-txt:{{ section.settings.card_text_color }};
  --ab-badge-bg:{{ section.settings.badge_bg }};
  --ab-badge-txt:{{ section.settings.badge_text }};
  --ab-eyebrow-bg:{{ section.settings.eyebrow_bg }};
  --ab-eyebrow-txt:{{ section.settings.eyebrow_text_color }};
  --ab-hero-txt:{{ section.settings.hero_text_color }};
  --ab-radius:{{ section.settings.card_radius }}px;
}

.ab{
  position:relative;
  background:
    radial-gradient(80% 60% at 8% 20%, color-mix(in srgb,var(--ab-accent) 6%,transparent) 0%, transparent 100%),
    radial-gradient(70% 50% at 92% 80%, color-mix(in srgb,var(--ab-badge-bg) 7%,transparent) 0%, transparent 100%),
    var(--ab-bg);
  padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  overflow:hidden;
}

.ab__wrap{
  max-width:1200px;
  margin:0 auto;
  padding:0 {{ section.settings.padding_h }}px;
}

/* ── Header ── */
.ab__header{
  text-align:center;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:{{ section.settings.header_gap }}px;
  margin-bottom:{{ section.settings.grid_top_gap }}px;
}

.ab__eyebrow{
  display:inline-flex;
  align-items:center;
  gap:6px;
  width:fit-content;
  padding:5px 14px;
  border-radius:999px;
  background:var(--ab-eyebrow-bg);
  color:var(--ab-eyebrow-txt);
  font-size:11px;
  font-weight:600;
  letter-spacing:.12em;
  text-transform:uppercase;
  line-height:1;
}

.ab__heading{
  font-size:clamp(1.75rem,3.8vw,{{ section.settings.heading_size }}px);
  font-weight:800;
  line-height:1.1;
  letter-spacing:-.03em;
  color:var(--ab-heading);
  margin:0;
  max-width:18ch;
  text-wrap:balance;
}

.ab__sub{
  font-size:{{ section.settings.sub_size }}px;
  line-height:1.6;
  color:var(--ab-sub);
  margin:0;
  max-width:52ch;
  text-wrap:pretty;
}

/* ── Bento Grid ── */
.ab__grid{
  display:grid;
  grid-template-columns:1fr 2fr 1fr;
  grid-template-rows:1fr 1fr;
  gap:{{ section.settings.grid_gap }}px;
}

.ab__card--tl{grid-area:1/1/2/2;align-self:end}
.ab__card--tr{grid-area:1/3/2/4;align-self:end}
.ab__card--bl{grid-area:2/1/3/2;align-self:start}
.ab__card--br{grid-area:2/3/3/4;align-self:start}
.ab__hero{grid-area:1/2/3/3}

/* ── Corner cards ── */
.ab__card{
  position:relative;
  border-radius:var(--ab-radius);
  overflow:hidden;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
  height:{{ section.settings.card_min_height }}px;
  transition:transform .35s ease,box-shadow .35s ease;
  cursor:default;
}
.ab__card:hover{
  transform:translateY(-4px);
  box-shadow:0 16px 40px rgba(0,0,0,.12);
}

.ab__card-img{
  position:absolute;
  inset:0;
  width:100%;height:100%;
  object-fit:cover;
  display:block;
  transition:transform .6s ease;
}
.ab__card:hover .ab__card-img{transform:scale(1.06)}
.ab__card-img--ph{opacity:.3}

.ab__card-overlay{
  position:absolute;
  inset:0;
  z-index:1;
  transition:opacity .35s ease;
}
.ab__card-overlay--tl{
  background:
    linear-gradient(160deg, rgba(8,48,26,.18) 0%, rgba(8,48,26,0) 45%),
    linear-gradient(to top, rgba(5,28,16,.72) 0%, rgba(5,28,16,.16) 58%, rgba(5,28,16,0) 100%);
}
.ab__card-overlay--tr{
  background:
    linear-gradient(200deg, rgba(80,58,8,.2) 0%, rgba(80,58,8,0) 48%),
    linear-gradient(to top, rgba(20,30,18,.72) 0%, rgba(20,30,18,.16) 56%, rgba(20,30,18,0) 100%);
}
.ab__card-overlay--bl{
  background:
    linear-gradient(140deg, rgba(20,60,40,.2) 0%, rgba(20,60,40,0) 46%),
    linear-gradient(to top, rgba(8,28,22,.76) 0%, rgba(8,28,22,.18) 58%, rgba(8,28,22,0) 100%);
}
.ab__card-overlay--br{
  background:
    linear-gradient(215deg, rgba(74,126,47,.18) 0%, rgba(74,126,47,0) 46%),
    linear-gradient(to top, rgba(14,36,22,.74) 0%, rgba(14,36,22,.16) 56%, rgba(14,36,22,0) 100%);
}
.ab__card:hover .ab__card-overlay{opacity:.85}

.ab__card-content{
  position:relative;
  z-index:2;
  padding:{{ section.settings.card_padding }}px;
  display:flex;
  flex-direction:column;
  gap:6px;
  transform:translateY(4px);
  transition:transform .35s ease;
}
.ab__card:hover .ab__card-content{transform:translateY(0)}

.ab__card-title{
  font-size:{{ section.settings.card_title_size }}px;
  font-weight:700;
  line-height:1.25;
  color:var(--ab-card-txt);
  margin:0;
}

.ab__card-text{
  font-size:{{ section.settings.card_text_size }}px;
  line-height:1.5;
  color:color-mix(in srgb,var(--ab-card-txt) 82%,transparent);
  margin:0;
  opacity:0;
  transform:translateY(6px);
  transition:opacity .3s ease .05s,transform .3s ease .05s;
}
.ab__card:hover .ab__card-text{opacity:1;transform:translateY(0)}

/* ── Center hero card ── */
.ab__hero{
  position:relative;
  border-radius:var(--ab-radius);
  overflow:hidden;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
  min-height:{{ section.settings.hero_min_height }}px;
  box-shadow:0 20px 60px rgba(0,0,0,.1);
  transition:box-shadow .4s ease;
}
.ab__hero:hover{box-shadow:0 28px 70px rgba(0,0,0,.16)}

.ab__hero-img{
  position:absolute;
  inset:0;
  width:100%;height:100%;
  object-fit:cover;display:block;
  transition:transform .7s ease;
}
.ab__hero:hover .ab__hero-img{transform:scale(1.04)}
.ab__hero-img--ph{opacity:.3}

.ab__hero-overlay{
  position:absolute;
  inset:0;
  background:
    radial-gradient(100% 80% at 75% 15%, rgba(250,204,21,.14) 0%, rgba(250,204,21,0) 50%),
    linear-gradient(170deg, rgba(12,50,30,.2) 0%, rgba(12,50,30,0) 44%),
    linear-gradient(to top, rgba(0,0,0,.76) 0%, rgba(0,0,0,.3) 44%, rgba(0,0,0,0) 68%);
  z-index:1;
}

.ab__hero-content{
  position:relative;
  z-index:2;
  padding:{{ section.settings.hero_padding }}px;
  display:flex;
  flex-direction:column;
  gap:12px;
}

.ab__hero-badge{
  display:inline-block;
  width:fit-content;
  padding:6px 16px;
  border-radius:999px;
  background:var(--ab-badge-bg);
  color:var(--ab-badge-txt);
  font-size:11px;
  font-weight:700;
  letter-spacing:.08em;
  text-transform:uppercase;
}

.ab__hero-text{
  font-size:{{ section.settings.hero_text_size }}px;
  line-height:1.55;
  color:#ffffff;
  margin:0;
  max-width:440px;
}

/* ── Reveal animation ── */
.ab__header,.ab__card,.ab__hero{
  opacity:0;
  transform:translateY(24px);
  transition:opacity .6s ease,transform .6s ease;
}
.ab__header.ab__revealed{opacity:1;transform:translateY(0)}
.ab__hero.ab__revealed{opacity:1;transform:translateY(0);transition-delay:.1s}
.ab__card.ab__revealed{opacity:1;transform:translateY(0)}
.ab__card--tl.ab__revealed{transition-delay:.15s}
.ab__card--tr.ab__revealed{transition-delay:.22s}
.ab__card--bl.ab__revealed{transition-delay:.3s}
.ab__card--br.ab__revealed{transition-delay:.38s}

/* ── Tablet ── */
@media(max-width:991px) and (min-width:768px){
  .ab__grid{
    grid-template-columns:1fr 1.6fr 1fr;
    gap:{{ section.settings.grid_gap | minus: 2 }}px;
  }
  .ab__card{height:{{ section.settings.card_min_height | minus: 20 }}px}
  .ab__hero{min-height:{{ section.settings.hero_min_height | minus: 60 }}px}
  .ab__card-text{opacity:1;transform:none}
}

/* ── Mobile ── */
@media(max-width:767px){
  .ab__grid{
    grid-template-columns:1fr 1fr;
    grid-template-rows:auto;
    gap:{{ section.settings.grid_gap_mobile }}px;
  }
  .ab__card--tl,.ab__card--tr,.ab__card--bl,.ab__card--br{grid-area:auto;align-self:stretch}
  .ab__hero{grid-column:1/-1;order:-1;min-height:300px}
  .ab__card{height:{{ section.settings.card_min_height_mobile }}px}
  .ab__card-text{opacity:1;transform:none}
  .ab__card-content{transform:none}
  .ab__heading{
    font-size:clamp(1.5rem,6.5vw,{{ section.settings.heading_size_mobile }}px);
    line-height:1.14;
  }
  .ab__eyebrow{
    font-size:10px;
    padding:4px 12px;
    letter-spacing:.1em;
  }
  .ab__hero-text{font-size:14px}
}
</style>

<script>
(function(){
  function initAB(){
    var sec=document.getElementById('ab-{{ s_id }}');
    if(!sec)return;
    var items=sec.querySelectorAll('.ab__card,.ab__hero,.ab__header');
    if(!('IntersectionObserver' in window)){items.forEach(function(e){e.classList.add('ab__revealed')});return}
    var io=new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){e.target.classList.add('ab__revealed');io.unobserve(e.target)}
      });
    },{threshold:0.15,rootMargin:'0px 0px -40px 0px'});
    items.forEach(function(e){io.observe(e)});
  }
  if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',initAB)}else{initAB()}
  document.addEventListener('shopify:section:load',function(e){if(e.target.querySelector('#ab-{{ s_id }}'))initAB()});
})();
</script>

