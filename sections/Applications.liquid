{% comment %}Applications Bento Grid — sections/Applications.liquid{% endcomment %}

{%- liquid
  assign s_id = section.id
  assign cards = section.blocks | where: 'type', 'card'
-%}

<section class="ab" id="ab-{{ s_id }}">
  <div class="ab__wrap">

    {%- comment -%}── Header ──{%- endcomment -%}
    <div class="ab__header">
      <span class="ab__accent" aria-hidden="true"></span>
      {%- if section.settings.heading != blank -%}
        <h2 class="ab__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="ab__sub">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    {%- comment -%}── Bento Grid ──{%- endcomment -%}
    <div class="ab__grid">

      {%- comment -%}── Corner cards (positions 1–4) ──{%- endcomment -%}
      {%- for block in cards -%}
        {%- case forloop.index -%}
          {%- when 1 -%}{%- assign pos = 'tl' -%}
          {%- when 2 -%}{%- assign pos = 'tr' -%}
          {%- when 3 -%}{%- assign pos = 'bl' -%}
          {%- when 4 -%}{%- assign pos = 'br' -%}
        {%- endcase -%}
        <div class="ab__card ab__card--{{ pos }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{- block.settings.image
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  widths: '400,600,800',
                  sizes: '(max-width: 767px) 50vw, 25vw',
                  class: 'ab__card-img',
                  alt: block.settings.title
            -}}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'ab__card-img ab__card-img--ph' }}
          {%- endif -%}
          <div class="ab__card-overlay"></div>
          <div class="ab__card-content">
            {%- if block.settings.title != blank -%}
              <h3 class="ab__card-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="ab__card-text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}

      {%- comment -%}── Center hero card ──{%- endcomment -%}
      <div class="ab__hero">
        {%- if section.settings.hero_image != blank -%}
          {{- section.settings.hero_image
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                widths: '600,800,1000,1200',
                sizes: '(max-width: 767px) 100vw, 50vw',
                class: 'ab__hero-img',
                alt: section.settings.hero_heading
          -}}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'ab__hero-img ab__hero-img--ph' }}
        {%- endif -%}
        <div class="ab__hero-overlay"></div>
        <div class="ab__hero-content">
          {%- if section.settings.hero_badge != blank -%}
            <span class="ab__hero-badge">{{ section.settings.hero_badge }}</span>
          {%- endif -%}
          {%- if section.settings.hero_heading != blank -%}
            <p class="ab__hero-text">{{ section.settings.hero_heading }}</p>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
#ab-{{ s_id }}{
  --ab-bg:{{ section.settings.bg_color }};
  --ab-heading:{{ section.settings.heading_color }};
  --ab-sub:{{ section.settings.subtext_color }};
  --ab-accent:{{ section.settings.accent_color }};
  --ab-card-txt:{{ section.settings.card_text_color }};
  --ab-badge-bg:{{ section.settings.badge_bg }};
  --ab-badge-txt:{{ section.settings.badge_text }};
  --ab-hero-txt:{{ section.settings.hero_text_color }};
  --ab-radius:{{ section.settings.card_radius }}px;
}

.ab{
  background:var(--ab-bg);
  padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
}

.ab__wrap{
  max-width:1200px;
  margin:0 auto;
  padding:0 {{ section.settings.padding_h }}px;
}

/* ── Header ── */
.ab__header{
  text-align:center;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:{{ section.settings.header_gap }}px;
  margin-bottom:{{ section.settings.grid_top_gap }}px;
}

.ab__accent{
  width:{{ section.settings.accent_width }}px;
  height:{{ section.settings.accent_height }}px;
  border-radius:99px;
  background:var(--ab-accent);
}

.ab__heading{
  font-size:{{ section.settings.heading_size }}px;
  font-weight:700;
  line-height:1.2;
  letter-spacing:-.02em;
  color:var(--ab-heading);
  margin:0;
}

.ab__sub{
  font-size:{{ section.settings.sub_size }}px;
  line-height:1.55;
  color:var(--ab-sub);
  margin:0;
  max-width:560px;
}

/* ── Bento Grid ── */
.ab__grid{
  display:grid;
  grid-template-columns:1fr 2fr 1fr;
  grid-template-rows:1fr 1fr;
  gap:{{ section.settings.grid_gap }}px;
}

.ab__card--tl{grid-area:1/1/2/2}
.ab__card--tr{grid-area:1/3/2/4}
.ab__card--bl{grid-area:2/1/3/2}
.ab__card--br{grid-area:2/3/3/4}
.ab__hero{grid-area:1/2/3/3}

/* ── Corner cards ── */
.ab__card{
  position:relative;
  border-radius:var(--ab-radius);
  overflow:hidden;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
  min-height:{{ section.settings.card_min_height }}px;
}

.ab__card-img{
  position:absolute;
  inset:0;
  width:100%;height:100%;
  object-fit:cover;
  display:block;
}
.ab__card-img--ph{opacity:.3}

.ab__card-overlay{
  position:absolute;
  inset:0;
  background:linear-gradient(to top,rgba(0,0,0,.65) 0%,rgba(0,0,0,.15) 55%,rgba(0,0,0,0) 100%);
  z-index:1;
}

.ab__card-content{
  position:relative;
  z-index:2;
  padding:{{ section.settings.card_padding }}px;
  display:flex;
  flex-direction:column;
  gap:6px;
}

.ab__card-title{
  font-size:{{ section.settings.card_title_size }}px;
  font-weight:700;
  line-height:1.25;
  color:var(--ab-card-txt);
  margin:0;
}

.ab__card-text{
  font-size:{{ section.settings.card_text_size }}px;
  line-height:1.5;
  color:color-mix(in srgb,var(--ab-card-txt) 85%,transparent);
  margin:0;
}

/* ── Center hero card ── */
.ab__hero{
  position:relative;
  border-radius:var(--ab-radius);
  overflow:hidden;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
}

.ab__hero-img{
  position:absolute;
  inset:0;
  width:100%;height:100%;
  object-fit:cover;display:block;
  transition:transform .5s ease;
}
.ab__hero:hover .ab__hero-img{transform:scale(1.03)}
.ab__hero-img--ph{opacity:.3}

.ab__hero-overlay{
  position:absolute;
  inset:0;
  background:linear-gradient(to top,rgba(0,0,0,.7) 0%,rgba(0,0,0,.25) 45%,rgba(0,0,0,0) 70%);
  z-index:1;
}

.ab__hero-content{
  position:relative;
  z-index:2;
  padding:{{ section.settings.hero_padding }}px;
  display:flex;
  flex-direction:column;
  gap:12px;
}

.ab__hero-badge{
  display:inline-block;
  width:fit-content;
  padding:6px 18px;
  border-radius:999px;
  background:var(--ab-badge-bg);
  color:var(--ab-badge-txt);
  font-size:12px;
  font-weight:700;
  letter-spacing:.06em;
  text-transform:uppercase;
}

.ab__hero-text{
  font-size:{{ section.settings.hero_text_size }}px;
  line-height:1.5;
  color:#ffffff;
  margin:0;
  max-width:480px;
}

/* ── Mobile ── */
@media(max-width:767px){
  .ab__grid{
    grid-template-columns:1fr 1fr;
    grid-template-rows:auto;
    gap:{{ section.settings.grid_gap_mobile }}px;
  }
  .ab__card--tl{grid-area:auto}
  .ab__card--tr{grid-area:auto}
  .ab__card--bl{grid-area:auto}
  .ab__card--br{grid-area:auto}
  .ab__hero{grid-column:1/-1;order:-1;min-height:280px}
  .ab__hero-media{min-height:220px}
  .ab__card{min-height:{{ section.settings.card_min_height_mobile }}px}
  .ab__heading{font-size:{{ section.settings.heading_size_mobile }}px}
}
</style>

{% schema %}
{
  "name": "Applications Grid",
  "tag": "section",
  "class": "applications-section",
  "settings": [

    { "type": "header", "content": "─── Colors ───────────────────────" },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext Color",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Bar Color",
      "default": "#0d7c5f"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "hero_text_color",
      "label": "Hero Description Color",
      "default": "#374151"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge Background",
      "default": "#d4a017"
    },
    {
      "type": "color",
      "id": "badge_text",
      "label": "Badge Text Color",
      "default": "#ffffff"
    },

    { "type": "header", "content": "─── Header Content ───────────────" },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Herbishield Works"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "info": "Optional subtitle below the heading"
    },

    { "type": "header", "content": "─── Center Hero Card ─────────────" },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image",
      "info": "Large center image. Recommended: 1200×800px"
    },
    {
      "type": "text",
      "id": "hero_badge",
      "label": "Badge Text",
      "default": "HERBISHIELD FORMULA"
    },
    {
      "type": "textarea",
      "id": "hero_heading",
      "label": "Hero Description",
      "default": "Professional-grade protection that keeps your crops healthy and thriving all season long."
    },

    { "type": "header", "content": "─── Typography ───────────────────" },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading — Desktop (px)",
      "min": 24, "max": 56, "step": 2,
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading — Mobile (px)",
      "min": 22, "max": 40, "step": 2,
      "default": 26
    },
    {
      "type": "range",
      "id": "sub_size",
      "label": "Subtext Size (px)",
      "min": 14, "max": 20, "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "card_title_size",
      "label": "Card Title Size (px)",
      "min": 14, "max": 22, "step": 1,
      "default": 17
    },
    {
      "type": "range",
      "id": "card_text_size",
      "label": "Card Description Size (px)",
      "min": 12, "max": 16, "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "hero_text_size",
      "label": "Hero Description Size (px)",
      "min": 14, "max": 20, "step": 1,
      "default": 16
    },

    { "type": "header", "content": "─── Layout ───────────────────────" },
    {
      "type": "range",
      "id": "accent_width",
      "label": "Accent Bar Width (px)",
      "min": 20, "max": 60, "step": 2,
      "default": 36
    },
    {
      "type": "range",
      "id": "accent_height",
      "label": "Accent Bar Height (px)",
      "min": 2, "max": 8, "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card Border Radius (px)",
      "min": 0, "max": 24, "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card Content Padding (px)",
      "min": 12, "max": 32, "step": 2,
      "default": 20
    },
    {
      "type": "range",
      "id": "hero_padding",
      "label": "Hero Body Padding (px)",
      "min": 16, "max": 40, "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "card_min_height",
      "label": "Corner Card Height — Desktop (px)",
      "min": 160, "max": 300, "step": 10,
      "default": 220
    },
    {
      "type": "range",
      "id": "card_min_height_mobile",
      "label": "Corner Card Height — Mobile (px)",
      "min": 140, "max": 260, "step": 10,
      "default": 180
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid Gap — Desktop (px)",
      "min": 8, "max": 28, "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "grid_gap_mobile",
      "label": "Grid Gap — Mobile (px)",
      "min": 8, "max": 20, "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "header_gap",
      "label": "Header Content Gap (px)",
      "min": 4, "max": 24, "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "grid_top_gap",
      "label": "Gap Between Header & Grid (px)",
      "min": 16, "max": 60, "step": 4,
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Section Padding Top (px)",
      "min": 0, "max": 120, "step": 4,
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Section Padding Bottom (px)",
      "min": 0, "max": 120, "step": 4,
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_h",
      "label": "Horizontal Padding (px)",
      "min": 16, "max": 80, "step": 4,
      "default": 24
    }

  ],
  "blocks": [
    {
      "type": "card",
      "name": "Feature Card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image",
          "info": "Recommended: 800×600px"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Concentrated Formula"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "An emulsifiable concentrate designed for efficient plant care support."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Applications Grid",
      "category": "Product",
      "blocks": [
        { "type": "card", "settings": { "title": "Concentrated Formula", "text": "An emulsifiable concentrate designed for efficient plant care support." } },
        { "type": "card", "settings": { "title": "Reliable Performance", "text": "Designed to support consistent plant health when used as directed." } },
        { "type": "card", "settings": { "title": "Supports Plant Vitality", "text": "Helps manage insect-related plant stress to maintain healthy growth conditions." } },
        { "type": "card", "settings": { "title": "Healthier Leaves & Stronger Growth", "text": "Helps maintain leaf strength and vitality across different types of crops." } }
      ]
    }
  ]
}
{% endschema %}
