{% comment %}Product Showcase — sections/NewProduct.liquid v3.0 — CRO-optimized{% endcomment %}

{%- liquid
  assign s_id = section.id
  assign features = section.blocks | where: 'type', 'feature'
  assign variants = section.blocks | where: 'type', 'size_variant'
  assign default_variant = nil
  for v in variants
    if v.settings.selected
      assign default_variant = v
      break
    endif
  endfor
  unless default_variant
    assign default_variant = variants.first
  endunless
-%}

<section class="np" id="np-{{ s_id }}">
  <div class="np__wrap">
    <div class="np__grid">

      {%- comment -%}── Left: Studio product display ──{%- endcomment -%}
      <div class="np__media np__reveal">
        <div class="np__studio">

          {%- if section.settings.cert_text != blank -%}
            <div class="np__cert">
              <svg class="np__cert-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
              <span>{{ section.settings.cert_text }}</span>
            </div>
          {%- endif -%}

          <div class="np__img-stage">
            <div class="np__img-frame np__img-frame--default{% if default_variant == nil or default_variant.settings.image == blank %} np__img-frame--active{% endif %}">
              {%- if section.settings.product_image != blank -%}
                {{- section.settings.product_image
                    | image_url: width: 900
                    | image_tag:
                      loading: 'eager',
                      widths: '400,600,900',
                      sizes: '(max-width: 767px) 80vw, 40vw',
                      class: 'np__product-img',
                      alt: section.settings.heading
                -}}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'np__product-img np__product-img--ph' }}
              {%- endif -%}
            </div>
            {%- for block in variants -%}
              {%- if block.settings.image != blank -%}
                <div class="np__img-frame{% if default_variant.id == block.id %} np__img-frame--active{% endif %}" data-variant-img="{{ block.id }}">
                  {{- block.settings.image
                      | image_url: width: 900
                      | image_tag:
                        loading: 'lazy',
                        widths: '400,600,900',
                        sizes: '(max-width: 767px) 80vw, 40vw',
                        class: 'np__product-img',
                        alt: block.settings.label
                  -}}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- assign show_coverage = false -%}
          {%- for v in variants -%}
            {%- if v.settings.coverage != blank -%}{%- assign show_coverage = true -%}{%- break -%}{%- endif -%}
          {%- endfor -%}
          {%- if show_coverage -%}
            <div class="np__coverage" data-np-coverage>
              <svg class="np__coverage-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M3 9h18M9 3v18"/></svg>
              <span class="np__coverage-txt">{{ default_variant.settings.coverage | default: '' }}</span>
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%}── Right: CRO-optimized info column ──{%- endcomment -%}
      <div class="np__info">

        {%- comment -%}1. Social proof — first thing the eye sees{%- endcomment -%}
        {%- if section.settings.review_rating != blank -%}
          <div class="np__proof np__reveal">
            <div class="np__stars">
              {%- assign star_count = section.settings.review_stars | default: 5 -%}
              {%- for i in (1..5) -%}
                <svg class="np__star{% if i > star_count %} np__star--empty{% endif %}" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              {%- endfor -%}
            </div>
            <span class="np__proof-rating">{{ section.settings.review_rating }}</span>
            <span class="np__proof-sep">·</span>
            <span class="np__proof-count">{{ section.settings.review_count }}</span>
          </div>
        {%- endif -%}

        {%- comment -%}2. Product name — clear, dominant{%- endcomment -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="np__heading np__reveal">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- comment -%}3. One-liner value proposition{%- endcomment -%}
        {%- if section.settings.description != blank -%}
          <p class="np__desc np__reveal">{{ section.settings.description }}</p>
        {%- endif -%}

        {%- comment -%}4. Benefit chips — scannable, compact{%- endcomment -%}
        {%- if features.size > 0 -%}
          <div class="np__chips np__reveal">
            {%- for block in features -%}
              <span class="np__chip" {{ block.shopify_attributes }}>
                <svg class="np__chip-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                {{ block.settings.text }}
              </span>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <hr class="np__divider np__reveal">

        {%- comment -%}5. Variant selector — shows coverage per size{%- endcomment -%}
        {%- if variants.size > 0 -%}
          <div class="np__variants np__reveal">
            <p class="np__variants-label">{{ section.settings.size_label }}</p>
            <div class="np__var-grid">
              {%- for block in variants -%}
                <button
                  class="np__var{% if block.settings.selected %} np__var--active{% endif %}"
                  type="button"
                  data-vid="{{ block.id }}"
                  data-price="{{ block.settings.price }}"
                  data-compare="{{ block.settings.compare_price }}"
                  data-coverage="{{ block.settings.coverage }}"
                  data-has-img="{% if block.settings.image != blank %}1{% else %}0{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.popular_tag != blank -%}
                    <span class="np__var-tag">{{ block.settings.popular_tag }}</span>
                  {%- endif -%}
                  <span class="np__var-size">{{ block.settings.label }}</span>
                  {%- if block.settings.coverage != blank -%}
                    <span class="np__var-cov">{{ block.settings.coverage }}</span>
                  {%- endif -%}
                  <span class="np__var-price">{{ block.settings.price }}</span>
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%}6. Price anchoring block{%- endcomment -%}
        <div class="np__price-block np__reveal">
          <div class="np__price-row">
            <span class="np__price" data-np-price>{{ section.settings.price }}</span>
            {%- if default_variant.settings.compare_price != blank -%}
              <span class="np__price-was" data-np-compare>{{ default_variant.settings.compare_price }}</span>
              <span class="np__savings" data-np-savings>SAVE</span>
            {%- else -%}
              <span class="np__price-was" data-np-compare style="display:none"></span>
              <span class="np__savings" data-np-savings style="display:none">SAVE</span>
            {%- endif -%}
          </div>
          {%- if section.settings.price_note != blank -%}
            <p class="np__price-note">{{ section.settings.price_note }}</p>
          {%- endif -%}
        </div>

        {%- comment -%}7. Primary CTA — full-width, high contrast{%- endcomment -%}
        <div class="np__cta-block np__reveal">
          {%- if section.settings.btn_primary_label != blank -%}
            <a href="{{ section.settings.btn_primary_url | default: '#' }}" class="np__cta">
              <svg class="np__cta-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
              <span data-np-cta-label>{{ section.settings.btn_primary_label }}</span>
              <span class="np__cta-price" data-np-cta-price>{{ section.settings.price }}</span>
            </a>
          {%- endif -%}
          {%- if section.settings.cta_micro != blank -%}
            <p class="np__cta-micro">{{ section.settings.cta_micro }}</p>
          {%- endif -%}
          {%- if section.settings.btn_secondary_label != blank -%}
            <a href="{{ section.settings.btn_secondary_url | default: '#' }}" class="np__link">
              {{ section.settings.btn_secondary_label }}
              <svg class="np__link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          {%- endif -%}
        </div>

        {%- comment -%}8. Trust strip — reduces purchase anxiety{%- endcomment -%}
        <div class="np__trust np__reveal">
          {%- if section.settings.trust_1 != blank -%}
            <div class="np__trust-item">
              <svg class="np__trust-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span>{{ section.settings.trust_1 }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings.trust_2 != blank -%}
            <div class="np__trust-item">
              <svg class="np__trust-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
              <span>{{ section.settings.trust_2 }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings.trust_3 != blank -%}
            <div class="np__trust-item">
              <svg class="np__trust-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              <span>{{ section.settings.trust_3 }}</span>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%}9. Urgency — optional scarcity signal{%- endcomment -%}
        {%- if section.settings.urgency_text != blank -%}
          <p class="np__urgency np__reveal">
            <span class="np__urgency-dot"></span>
            {{ section.settings.urgency_text }}
          </p>
        {%- endif -%}

      </div>
    </div>
  </div>
</section>

<style>
#np-{{ s_id }}{
  --np-bg:{{ section.settings.bg_color }};
  --np-studio-from:{{ section.settings.studio_bg_from | default: '#ffffff' }};
  --np-studio-to:{{ section.settings.studio_bg_to | default: '#f4f9f5' }};
  --np-badge:{{ section.settings.badge_bg_color }};
  --np-badge-txt:{{ section.settings.badge_text_color }};
  --np-heading:{{ section.settings.heading_color }};
  --np-desc:{{ section.settings.desc_color }};
  --np-icon:{{ section.settings.feature_icon_color }};
  --np-feat:{{ section.settings.feature_text_color }};
  --np-border:{{ section.settings.card_border_color }};
  --np-active:{{ section.settings.active_border_color }};
  --np-tag:{{ section.settings.popular_tag_color }};
  --np-price-c:{{ section.settings.price_color }};
  --np-note:{{ section.settings.price_note_color }};
  --np-btn-bg:{{ section.settings.btn_primary_bg }};
  --np-btn-txt:{{ section.settings.btn_primary_text }};
  --np-btn2-txt:{{ section.settings.btn_secondary_text | default: '#1a4d1e' }};
  --np-trust-c:{{ section.settings.trust_color | default: '#0d7c5f' }};
  --np-star:{{ section.settings.star_color | default: '#f59e0b' }};
}

/* ══════════════════════════════════════
   Section shell
   ══════════════════════════════════════ */
.np{
  background:var(--np-bg);
  padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  overflow:hidden;
}
.np__wrap{
  max-width:{{ section.settings.max_width }}px;
  margin:0 auto;
  padding:0 {{ section.settings.padding_h }}px;
}
.np__grid{
  display:flex;
  align-items:flex-start;
  gap:{{ section.settings.grid_gap }}px;
  {%- if section.settings.image_side == 'right' -%}flex-direction:row-reverse;{%- endif -%}
}

/* ══════════════════════════════════════
   Studio — clean product display
   ══════════════════════════════════════ */
.np__media{
  flex:0 0 {{ section.settings.image_col_width }}%;
  max-width:{{ section.settings.image_col_width }}%;
  position:sticky;
  top:100px;
}
.np__studio{
  position:relative;
  background:linear-gradient(165deg, var(--np-studio-from), var(--np-studio-to));
  border-radius:1.75rem;
  border:1px solid rgba(0,0,0,.04);
  box-shadow:0 25px 60px -12px rgba(0,60,30,.06);
  padding:40px 24px 28px;
  overflow:hidden;
}

/* Certification badge */
.np__cert{
  position:absolute;
  top:16px;left:16px;
  display:inline-flex;
  align-items:center;
  gap:5px;
  padding:5px 12px;
  border-radius:999px;
  background:rgba(255,255,255,.85);
  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);
  border:1px solid rgba(255,255,255,.5);
  font-size:11px;
  font-weight:600;
  color:var(--np-active);
  z-index:5;
}
.np__cert-ico{width:14px;height:14px;flex-shrink:0}

/* Image stage */
.np__img-stage{
  position:relative;
  width:100%;
  aspect-ratio:3/4;
}
.np__img-frame{
  position:absolute;
  inset:0;
  display:flex;
  align-items:center;
  justify-content:center;
  opacity:0;
  transition:opacity .4s ease;
  pointer-events:none;
}
.np__img-frame--active{opacity:1;pointer-events:auto}
.np__product-img{
  width:72%;
  max-height:88%;
  object-fit:contain;
  mix-blend-mode:multiply;
  filter:drop-shadow(0 16px 36px rgba(0,0,0,.08));
  display:block;
}
.np__img-frame--active .np__product-img{
  animation:np-float 5s ease-in-out infinite;
}
.np__product-img--ph{width:55%;opacity:.3;mix-blend-mode:normal}

@keyframes np-float{
  0%,100%{transform:translateY(0)}
  50%{transform:translateY(-8px)}
}

/* Coverage pill */
.np__coverage{
  position:absolute;
  bottom:14px;
  left:50%;
  transform:translateX(-50%);
  display:inline-flex;
  align-items:center;
  gap:5px;
  padding:6px 16px;
  border-radius:999px;
  background:rgba(255,255,255,.82);
  backdrop-filter:blur(14px);
  -webkit-backdrop-filter:blur(14px);
  border:1px solid rgba(255,255,255,.5);
  box-shadow:0 4px 16px rgba(0,0,0,.05);
  font-size:11px;
  font-weight:600;
  color:var(--np-active);
  white-space:nowrap;
  transition:opacity .3s ease;
  z-index:5;
}
.np__coverage-ico{width:14px;height:14px;flex-shrink:0;opacity:.65}

/* ══════════════════════════════════════
   Info column — CRO hierarchy
   ══════════════════════════════════════ */
.np__info{
  flex:1;
  min-width:0;
  display:flex;
  flex-direction:column;
  gap:{{ section.settings.info_gap }}px;
}

/* 1. Social proof */
.np__proof{
  display:flex;
  align-items:center;
  gap:6px;
  flex-wrap:wrap;
}
.np__stars{display:flex;gap:1px}
.np__star{width:16px;height:16px;color:var(--np-star)}
.np__star--empty{opacity:.25}
.np__proof-rating{font-size:14px;font-weight:700;color:var(--np-heading)}
.np__proof-sep{font-size:14px;color:var(--np-note)}
.np__proof-count{font-size:14px;font-weight:500;color:var(--np-desc)}

/* 2. Heading */
.np__heading{
  font-size:clamp(1.65rem,3.4vw,{{ section.settings.heading_size }}px);
  font-weight:800;
  line-height:1.08;
  letter-spacing:-.025em;
  color:var(--np-heading);
  margin:0;
  text-wrap:balance;
}

/* 3. Description */
.np__desc{
  font-size:{{ section.settings.desc_size }}px;
  line-height:1.65;
  color:var(--np-desc);
  margin:0;
  max-width:520px;
}

/* 4. Benefit chips */
.np__chips{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
}
.np__chip{
  display:inline-flex;
  align-items:center;
  gap:6px;
  padding:7px 14px;
  border-radius:999px;
  background:color-mix(in srgb,var(--np-icon) 8%,transparent);
  font-size:13px;
  font-weight:600;
  color:var(--np-feat);
  white-space:nowrap;
}
.np__chip-ico{
  width:15px;height:15px;
  color:var(--np-icon);
  flex-shrink:0;
}

/* Divider */
.np__divider{
  border:none;
  height:1px;
  background:color-mix(in srgb,var(--np-border) 60%,transparent);
  margin:0;
}

/* 5. Variant selector */
.np__variants{display:flex;flex-direction:column;gap:10px}
.np__variants-label{margin:0;font-size:14px;font-weight:700;color:var(--np-heading)}
.np__var-grid{display:flex;flex-wrap:wrap;gap:8px}
.np__var{
  position:relative;
  min-width:90px;
  padding:12px 16px 10px;
  border:2px solid var(--np-border);
  border-radius:12px;
  background:#fff;
  cursor:pointer;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:2px;
  transition:all .2s ease;
}
.np__var:hover{
  border-color:color-mix(in srgb,var(--np-active) 40%,var(--np-border));
  transform:translateY(-2px);
  box-shadow:0 4px 12px rgba(0,0,0,.06);
}
.np__var--active{
  border-color:var(--np-active);
  background:color-mix(in srgb,var(--np-active) 4%,#fff);
  box-shadow:0 0 0 1px var(--np-active),0 6px 20px color-mix(in srgb,var(--np-active) 10%,transparent);
  transform:translateY(-2px);
}
.np__var-tag{
  position:absolute;
  top:-9px;left:50%;transform:translateX(-50%);
  padding:2px 10px;
  border-radius:999px;
  background:var(--np-tag);
  color:#fff;
  font-size:9px;
  font-weight:700;
  letter-spacing:.06em;
  text-transform:uppercase;
  white-space:nowrap;
}
.np__var-size{font-size:15px;font-weight:700;color:var(--np-heading)}
.np__var-cov{font-size:11px;font-weight:500;color:var(--np-icon);opacity:.85}
.np__var-price{font-size:13px;font-weight:600;color:var(--np-active)}

/* 6. Price anchoring */
.np__price-block{display:flex;flex-direction:column;gap:4px}
.np__price-row{display:flex;align-items:baseline;gap:10px;flex-wrap:wrap}
.np__price{
  font-size:{{ section.settings.price_size }}px;
  font-weight:800;
  color:var(--np-price-c);
  letter-spacing:-.02em;
  line-height:1;
  transition:opacity .2s ease;
}
.np__price-was{
  font-size:18px;
  font-weight:500;
  color:var(--np-note);
  text-decoration:line-through;
  transition:opacity .2s ease;
}
.np__savings{
  display:inline-block;
  padding:3px 10px;
  border-radius:999px;
  background:color-mix(in srgb,var(--np-icon) 12%,transparent);
  color:var(--np-icon);
  font-size:11px;
  font-weight:700;
  letter-spacing:.04em;
  transition:opacity .2s ease;
}
.np__price-note{margin:0;font-size:13px;color:var(--np-note);line-height:1.4}

/* 7. CTA block */
.np__cta-block{display:flex;flex-direction:column;gap:12px;align-items:flex-start}
.np__cta{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:10px;
  width:100%;
  padding:16px 32px;
  border-radius:{{ section.settings.btn_radius }}px;
  background:var(--np-btn-bg);
  color:var(--np-btn-txt);
  font-size:16px;
  font-weight:700;
  text-decoration:none;
  border:none;
  cursor:pointer;
  transition:transform .15s ease,box-shadow .2s ease;
  position:relative;
  overflow:hidden;
}
.np__cta::after{
  content:'';
  position:absolute;
  inset:0;
  background:linear-gradient(rgba(255,255,255,.08),rgba(255,255,255,0));
  pointer-events:none;
}
.np__cta:hover{
  transform:translateY(-2px);
  box-shadow:0 12px 32px color-mix(in srgb,var(--np-btn-bg) 30%,transparent);
}
.np__cta:active{transform:translateY(0);box-shadow:none}
.np__cta-ico{width:20px;height:20px;flex-shrink:0}
.np__cta-price{
  opacity:.75;
  font-weight:600;
  margin-left:4px;
}
.np__cta-price::before{content:'— '}

.np__cta-micro{
  margin:0;
  font-size:12px;
  color:var(--np-note);
  text-align:center;
  width:100%;
}

.np__link{
  display:inline-flex;
  align-items:center;
  gap:6px;
  font-size:14px;
  font-weight:600;
  color:var(--np-btn2-txt);
  text-decoration:none;
  transition:gap .2s ease;
}
.np__link:hover{gap:10px}
.np__link-arrow{width:16px;height:16px;flex-shrink:0}

/* 8. Trust strip */
.np__trust{
  display:flex;
  flex-wrap:wrap;
  gap:16px;
  padding-top:8px;
  border-top:1px solid color-mix(in srgb,var(--np-border) 50%,transparent);
}
.np__trust-item{
  display:flex;
  align-items:center;
  gap:6px;
  font-size:12px;
  font-weight:500;
  color:var(--np-feat);
}
.np__trust-ico{width:16px;height:16px;color:var(--np-trust-c);flex-shrink:0}

/* 9. Urgency */
.np__urgency{
  display:inline-flex;
  align-items:center;
  gap:8px;
  width:fit-content;
  margin:0;
  padding:6px 16px;
  border-radius:999px;
  background:color-mix(in srgb,#ef4444 8%,transparent);
  font-size:13px;
  font-weight:600;
  color:#dc2626;
}
.np__urgency-dot{
  width:7px;height:7px;
  border-radius:50%;
  background:#ef4444;
  animation:np-pulse 1.4s ease-in-out infinite;
}
@keyframes np-pulse{
  0%,100%{opacity:1;transform:scale(1)}
  50%{opacity:.35;transform:scale(.65)}
}

/* ══════════════════════════════════════
   Scroll-reveal stagger
   ══════════════════════════════════════ */
.np__reveal{
  opacity:0;
  transform:translateY(18px);
  transition:opacity .5s ease,transform .5s ease;
}
.np__reveal--visible{opacity:1;transform:translateY(0)}
.np__info .np__reveal:nth-child(2){transition-delay:.06s}
.np__info .np__reveal:nth-child(3){transition-delay:.12s}
.np__info .np__reveal:nth-child(4){transition-delay:.18s}
.np__info .np__reveal:nth-child(5){transition-delay:.22s}
.np__info .np__reveal:nth-child(6){transition-delay:.26s}
.np__info .np__reveal:nth-child(7){transition-delay:.3s}
.np__info .np__reveal:nth-child(8){transition-delay:.34s}
.np__info .np__reveal:nth-child(9){transition-delay:.38s}
.np__info .np__reveal:nth-child(10){transition-delay:.42s}

/* ══════════════════════════════════════
   Tablet (768-991)
   ══════════════════════════════════════ */
@media(max-width:991px) and (min-width:768px){
  .np__grid{gap:28px}
  .np__media{flex:0 0 40%;max-width:40%;position:static}
  .np__studio{padding:28px 16px 22px;border-radius:1.25rem}
  .np__heading{font-size:clamp(1.4rem,3vw,{{ section.settings.heading_size | minus: 8 }}px)}
  .np__var{min-width:75px;padding:10px 12px 8px}
  .np__cta{padding:14px 24px;font-size:15px}
}

/* ══════════════════════════════════════
   Mobile (<768)
   ══════════════════════════════════════ */
@media(max-width:767px){
  .np{padding:{{ section.settings.padding_top | divided_by: 2 }}px 0 {{ section.settings.padding_bottom | divided_by: 2 }}px}
  .np__grid{flex-direction:column!important;gap:24px}
  .np__media{flex:none;max-width:none;width:100%;position:static}
  .np__studio{
    max-width:340px;
    margin:0 auto;
    padding:28px 16px 22px;
    border-radius:1.25rem;
  }
  .np__heading{
    font-size:clamp(1.4rem,6vw,{{ section.settings.heading_size_mobile }}px);
    line-height:1.12;
  }
  .np__desc{font-size:14px}
  .np__chips{gap:6px}
  .np__chip{font-size:12px;padding:6px 11px}
  .np__var-grid{width:100%}
  .np__var{flex:1;min-width:70px;padding:10px 8px 8px}
  .np__var-size{font-size:14px}
  .np__var-cov{font-size:10px}
  .np__var-price{font-size:12px}
  .np__price{font-size:{{ section.settings.price_size | minus: 6 }}px}
  .np__cta{padding:15px 20px;font-size:15px}
  .np__trust{gap:12px}
  .np__trust-item{font-size:11px}
  .np__coverage{font-size:10px;padding:5px 12px}
  .np__cert{font-size:10px;padding:4px 10px}
  .np__reveal{opacity:1;transform:none;transition:none}
}
</style>

<script>
(function(){
  function initNP(){
    var sec=document.getElementById('np-{{ s_id }}');
    if(!sec)return;

    var priceEl=sec.querySelector('[data-np-price]');
    var compareEl=sec.querySelector('[data-np-compare]');
    var savingsEl=sec.querySelector('[data-np-savings]');
    var ctaPriceEl=sec.querySelector('[data-np-cta-price]');
    var coverageWrap=sec.querySelector('[data-np-coverage]');
    var coverageTxt=coverageWrap?coverageWrap.querySelector('.np__coverage-txt'):null;
    var defaultFrame=sec.querySelector('.np__img-frame--default');
    var btns=sec.querySelectorAll('.np__var');

    btns.forEach(function(btn){
      btn.addEventListener('click',function(){
        sec.querySelectorAll('.np__var--active').forEach(function(el){el.classList.remove('np__var--active')});
        btn.classList.add('np__var--active');

        var price=btn.getAttribute('data-price');
        var compare=btn.getAttribute('data-compare');
        var coverage=btn.getAttribute('data-coverage');
        var vid=btn.getAttribute('data-vid');
        var hasImg=btn.getAttribute('data-has-img')==='1';

        if(priceEl&&price){priceEl.textContent=price}
        if(ctaPriceEl&&price){ctaPriceEl.textContent=price}

        if(compareEl&&savingsEl){
          if(compare){
            compareEl.textContent=compare;compareEl.style.display='';
            savingsEl.style.display='';
          }else{
            compareEl.style.display='none';savingsEl.style.display='none';
          }
        }

        if(coverageTxt){
          if(coverage){coverageTxt.textContent=coverage;if(coverageWrap)coverageWrap.style.opacity='1'}
          else{if(coverageWrap)coverageWrap.style.opacity='0'}
        }

        sec.querySelectorAll('.np__img-frame--active').forEach(function(f){f.classList.remove('np__img-frame--active')});
        var targetFrame=hasImg?sec.querySelector('[data-variant-img="'+vid+'"]'):null;
        if(targetFrame){targetFrame.classList.add('np__img-frame--active')}
        else if(defaultFrame){defaultFrame.classList.add('np__img-frame--active')}
      });
    });

    if('IntersectionObserver' in window){
      var io=new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if(e.isIntersecting){e.target.classList.add('np__reveal--visible');io.unobserve(e.target)}
        });
      },{threshold:0.1,rootMargin:'0px 0px -30px 0px'});
      sec.querySelectorAll('.np__reveal').forEach(function(el){io.observe(el)});
    }else{
      sec.querySelectorAll('.np__reveal').forEach(function(el){el.classList.add('np__reveal--visible')});
    }
  }

  if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',initNP)}else{initNP()}
  document.addEventListener('shopify:section:load',function(e){if(e.target.querySelector('#np-{{ s_id }}'))initNP()});
})();
</script>

