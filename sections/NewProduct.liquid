{% comment %}Product Showcase — sections/NewProduct.liquid v2.0{% endcomment %}

{%- liquid
  assign s_id = section.id
  assign features = section.blocks | where: 'type', 'feature'
  assign variants = section.blocks | where: 'type', 'size_variant'
  assign default_variant = nil
  for v in variants
    if v.settings.selected
      assign default_variant = v
      break
    endif
  endfor
  unless default_variant
    assign default_variant = variants.first
  endunless
-%}

<section class="np" id="np-{{ s_id }}">
  <div class="np__wrap">
    <div class="np__grid">

      {%- comment -%}── Left: Studio image container ──{%- endcomment -%}
      <div class="np__img-col np__reveal">
        <div class="np__studio">
          <div class="np__img-stage">
            {%- comment -%}Default section image (fallback){%- endcomment -%}
            <div class="np__img-frame np__img-frame--default{% if default_variant == nil or default_variant.settings.image == blank %} np__img-frame--active{% endif %}">
              {%- if section.settings.product_image != blank -%}
                {{- section.settings.product_image
                    | image_url: width: 900
                    | image_tag:
                      loading: 'eager',
                      widths: '400,600,900',
                      sizes: '(max-width: 767px) 80vw, 40vw',
                      class: 'np__product-img',
                      alt: section.settings.heading
                -}}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'np__product-img np__product-img--ph' }}
              {%- endif -%}
            </div>

            {%- comment -%}Per-variant images{%- endcomment -%}
            {%- for block in variants -%}
              {%- if block.settings.image != blank -%}
                <div class="np__img-frame{% if default_variant.id == block.id %} np__img-frame--active{% endif %}" data-variant-img="{{ block.id }}">
                  {{- block.settings.image
                      | image_url: width: 900
                      | image_tag:
                        loading: 'lazy',
                        widths: '400,600,900',
                        sizes: '(max-width: 767px) 80vw, 40vw',
                        class: 'np__product-img',
                        alt: block.settings.label
                  -}}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- comment -%}Floating coverage badge{%- endcomment -%}
          {%- assign show_coverage = false -%}
          {%- for v in variants -%}
            {%- if v.settings.coverage != blank -%}{%- assign show_coverage = true -%}{%- break -%}{%- endif -%}
          {%- endfor -%}
          {%- if show_coverage -%}
            <div class="np__coverage" data-np-coverage>
              <svg class="np__coverage-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M3 9h18M9 3v18"/></svg>
              <span class="np__coverage-txt">{{ default_variant.settings.coverage | default: '' }}</span>
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%}── Right: Product info ──{%- endcomment -%}
      <div class="np__info-col">

        {%- if section.settings.badge_text != blank -%}
          <div class="np__badge np__reveal">
            <svg class="np__badge-ico" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <span>{{ section.settings.badge_text }}</span>
          </div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="np__heading np__reveal">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <p class="np__desc np__reveal">{{ section.settings.description }}</p>
        {%- endif -%}

        {%- if features.size > 0 -%}
          <ul class="np__features np__reveal">
            {%- for block in features -%}
              <li class="np__feat" {{ block.shopify_attributes }}>
                <span class="np__feat-icon">
                  {%- case block.settings.icon -%}
                    {%- when 'shield' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
                    {%- when 'leaf' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-3.8 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
                    {%- when 'flask' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6M12 3v7.4a2 2 0 0 1-.5 1.3L5 19a2 2 0 0 0 1.5 3h11a2 2 0 0 0 1.5-3l-6.5-7.3a2 2 0 0 1-.5-1.3V3"/></svg>
                    {%- when 'droplet' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/></svg>
                  {%- endcase -%}
                </span>
                <span class="np__feat-text">{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if variants.size > 0 -%}
          <div class="np__variants np__reveal">
            <p class="np__variants-label">{{ section.settings.size_label }}</p>
            <div class="np__variants-row">
              {%- for block in variants -%}
                <button
                  class="np__var{% if block.settings.selected %} np__var--active{% endif %}"
                  type="button"
                  data-vid="{{ block.id }}"
                  data-price="{{ block.settings.price }}"
                  data-compare="{{ block.settings.compare_price }}"
                  data-coverage="{{ block.settings.coverage }}"
                  data-has-img="{% if block.settings.image != blank %}1{% else %}0{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.popular_tag != blank -%}
                    <span class="np__var-tag">{{ block.settings.popular_tag }}</span>
                  {%- endif -%}
                  <span class="np__var-name">{{ block.settings.label }}</span>
                  <span class="np__var-price">{{ block.settings.price }}</span>
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        <div class="np__price-block np__reveal">
          <div class="np__price-row">
            <span class="np__price" data-np-price>{{ section.settings.price }}</span>
            {%- if default_variant.settings.compare_price != blank -%}
              <span class="np__price-was" data-np-compare>{{ default_variant.settings.compare_price }}</span>
            {%- else -%}
              <span class="np__price-was" data-np-compare style="display:none"></span>
            {%- endif -%}
          </div>
          {%- if section.settings.price_note != blank -%}
            <p class="np__price-note">{{ section.settings.price_note }}</p>
          {%- endif -%}
        </div>

        <div class="np__trust np__reveal">
          {%- if section.settings.trust_1 != blank -%}
            <div class="np__trust-item">
              <svg class="np__trust-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span>{{ section.settings.trust_1 }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings.trust_2 != blank -%}
            <div class="np__trust-item">
              <svg class="np__trust-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
              <span>{{ section.settings.trust_2 }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings.trust_3 != blank -%}
            <div class="np__trust-item">
              <svg class="np__trust-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              <span>{{ section.settings.trust_3 }}</span>
            </div>
          {%- endif -%}
        </div>

        <div class="np__ctas np__reveal">
          {%- if section.settings.btn_primary_label != blank -%}
            <a href="{{ section.settings.btn_primary_url | default: '#' }}" class="np__btn np__btn--p">
              <svg class="np__btn-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
              {{ section.settings.btn_primary_label }}
            </a>
          {%- endif -%}
          {%- if section.settings.btn_secondary_label != blank -%}
            <a href="{{ section.settings.btn_secondary_url | default: '#' }}" class="np__btn np__btn--s">
              {{ section.settings.btn_secondary_label }}
            </a>
          {%- endif -%}
        </div>

        {%- if section.settings.urgency_text != blank -%}
          <p class="np__urgency np__reveal">
            <span class="np__urgency-dot"></span>
            {{ section.settings.urgency_text }}
          </p>
        {%- endif -%}

      </div>
    </div>
  </div>
</section>

<style>
#np-{{ s_id }}{
  --np-bg:{{ section.settings.bg_color }};
  --np-studio-from:{{ section.settings.studio_bg_from | default: '#ffffff' }};
  --np-studio-to:{{ section.settings.studio_bg_to | default: '#f4f9f5' }};
  --np-badge:{{ section.settings.badge_bg_color }};
  --np-badge-txt:{{ section.settings.badge_text_color }};
  --np-heading:{{ section.settings.heading_color }};
  --np-desc:{{ section.settings.desc_color }};
  --np-icon:{{ section.settings.feature_icon_color }};
  --np-feat:{{ section.settings.feature_text_color }};
  --np-border:{{ section.settings.card_border_color }};
  --np-active:{{ section.settings.active_border_color }};
  --np-tag:{{ section.settings.popular_tag_color }};
  --np-price-c:{{ section.settings.price_color }};
  --np-note:{{ section.settings.price_note_color }};
  --np-btn-bg:{{ section.settings.btn_primary_bg }};
  --np-btn-txt:{{ section.settings.btn_primary_text }};
  --np-btn2-border:{{ section.settings.btn_secondary_border }};
  --np-btn2-txt:{{ section.settings.btn_secondary_text }};
  --np-trust-c:{{ section.settings.trust_color | default: '#0d7c5f' }};
}

/* ── Section ── */
.np{
  background:var(--np-bg);
  padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  overflow:hidden;
}
.np__wrap{
  max-width:{{ section.settings.max_width }}px;
  margin:0 auto;
  padding:0 {{ section.settings.padding_h }}px;
}
.np__grid{
  display:flex;
  align-items:center;
  gap:{{ section.settings.grid_gap }}px;
  {%- if section.settings.image_side == 'right' -%}flex-direction:row-reverse;{%- endif -%}
}

/* ── Studio container ── */
.np__img-col{
  flex:0 0 {{ section.settings.image_col_width }}%;
  max-width:{{ section.settings.image_col_width }}%;
}
.np__studio{
  position:relative;
  background:linear-gradient(to bottom, var(--np-studio-from), var(--np-studio-to));
  border-radius:2rem;
  border:1px solid rgba(0,0,0,.04);
  box-shadow:
    0 25px 50px -12px rgba(0,60,30,.07),
    0 0 0 1px rgba(0,0,0,.02);
  padding:32px 20px;
  overflow:hidden;
}
.np__img-stage{
  position:relative;
  width:100%;
  aspect-ratio:3/4;
}
.np__img-frame{
  position:absolute;
  inset:0;
  display:flex;
  align-items:center;
  justify-content:center;
  opacity:0;
  transition:opacity .45s ease;
  pointer-events:none;
}
.np__img-frame--active{
  opacity:1;
  pointer-events:auto;
}
.np__product-img{
  width:70%;
  max-height:90%;
  object-fit:contain;
  mix-blend-mode:multiply;
  filter:drop-shadow(0 20px 40px rgba(0,0,0,.08));
  display:block;
}
.np__img-frame--active .np__product-img{
  animation:np-float 4s ease-in-out infinite;
}
.np__product-img--ph{width:55%;opacity:.35;mix-blend-mode:normal}

@keyframes np-float{
  0%,100%{transform:translateY(0)}
  50%{transform:translateY(-10px)}
}

/* Coverage badge (glassmorphism) */
.np__coverage{
  position:absolute;
  bottom:16px;
  left:50%;
  transform:translateX(-50%);
  display:inline-flex;
  align-items:center;
  gap:6px;
  padding:8px 18px;
  border-radius:999px;
  background:rgba(255,255,255,.82);
  backdrop-filter:blur(14px);
  -webkit-backdrop-filter:blur(14px);
  box-shadow:0 4px 20px rgba(0,0,0,.06);
  border:1px solid rgba(255,255,255,.6);
  font-size:12px;
  font-weight:600;
  color:var(--np-active);
  white-space:nowrap;
  transition:opacity .3s ease;
}
.np__coverage-ico{width:15px;height:15px;flex-shrink:0;opacity:.7}

/* ── Info column ── */
.np__info-col{
  flex:1;
  min-width:0;
  display:flex;
  flex-direction:column;
  gap:{{ section.settings.info_gap }}px;
}

/* ── Badge ── */
.np__badge{
  display:inline-flex;
  align-items:center;
  gap:6px;
  width:fit-content;
  padding:5px 14px;
  border-radius:999px;
  background:var(--np-badge);
  color:var(--np-badge-txt);
  font-size:11px;
  font-weight:700;
  letter-spacing:.08em;
  text-transform:uppercase;
}
.np__badge-ico{width:13px;height:13px;flex-shrink:0}

/* ── Heading ── */
.np__heading{
  font-size:clamp(1.75rem,3.5vw,{{ section.settings.heading_size }}px);
  font-weight:800;
  line-height:1.08;
  letter-spacing:-.025em;
  color:var(--np-heading);
  margin:0;
  text-wrap:balance;
}

/* ── Description ── */
.np__desc{
  font-size:{{ section.settings.desc_size }}px;
  line-height:1.65;
  color:var(--np-desc);
  margin:0;
  max-width:520px;
}

/* ── Features ── */
.np__features{
  list-style:none;
  margin:0;
  padding:0;
  display:flex;
  flex-direction:column;
  gap:12px;
}
.np__feat{
  display:flex;
  align-items:center;
  gap:14px;
}
.np__feat-icon{
  width:38px;height:38px;
  border-radius:10px;
  background:color-mix(in srgb,var(--np-icon) 10%,transparent);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
  transition:transform .2s ease;
}
.np__feat:hover .np__feat-icon{transform:scale(1.08)}
.np__feat-icon svg{width:19px;height:19px;color:var(--np-icon)}
.np__feat-text{
  font-size:{{ section.settings.feat_size }}px;
  font-weight:500;
  color:var(--np-feat);
}

/* ── Variant selector ── */
.np__variants{display:flex;flex-direction:column;gap:10px}
.np__variants-label{margin:0;font-size:14px;font-weight:700;color:var(--np-heading);letter-spacing:.01em}
.np__variants-row{display:flex;flex-wrap:wrap;gap:10px}
.np__var{
  position:relative;
  min-width:80px;
  padding:14px 18px 12px;
  border:2px solid var(--np-border);
  border-radius:12px;
  background:transparent;
  cursor:pointer;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:2px;
  transition:border-color .25s ease,box-shadow .25s ease,transform .2s ease;
}
.np__var:hover{
  border-color:color-mix(in srgb,var(--np-active) 45%,var(--np-border));
  transform:translateY(-2px);
}
.np__var--active{
  border-color:var(--np-active);
  box-shadow:0 0 0 1px var(--np-active),0 6px 20px color-mix(in srgb,var(--np-active) 14%,transparent);
  transform:translateY(-2px);
}
.np__var-tag{
  position:absolute;
  top:-10px;left:50%;transform:translateX(-50%);
  padding:2px 10px;
  border-radius:999px;
  background:var(--np-tag);
  color:#fff;
  font-size:10px;
  font-weight:700;
  letter-spacing:.04em;
  text-transform:uppercase;
  white-space:nowrap;
}
.np__var-name{font-size:15px;font-weight:700;color:var(--np-heading)}
.np__var-price{font-size:13px;font-weight:600;color:var(--np-active)}

/* ── Price block ── */
.np__price-block{
  display:flex;
  flex-direction:column;
  gap:4px;
  padding-top:8px;
  border-top:1px solid color-mix(in srgb,var(--np-border) 50%,transparent);
}
.np__price-row{display:flex;align-items:baseline;gap:12px}
.np__price{
  font-size:{{ section.settings.price_size }}px;
  font-weight:800;
  color:var(--np-price-c);
  letter-spacing:-.02em;
  line-height:1;
  transition:opacity .3s ease;
}
.np__price-was{
  font-size:18px;
  font-weight:500;
  color:var(--np-note);
  text-decoration:line-through;
  transition:opacity .3s ease;
}
.np__price-note{margin:0;font-size:13px;color:var(--np-note);line-height:1.4}

/* ── Trust bar ── */
.np__trust{
  display:flex;
  flex-wrap:wrap;
  gap:18px;
}
.np__trust-item{
  display:flex;
  align-items:center;
  gap:7px;
  font-size:13px;
  font-weight:500;
  color:var(--np-feat);
}
.np__trust-ico{
  width:18px;height:18px;
  color:var(--np-trust-c);
  flex-shrink:0;
}

/* ── CTAs ── */
.np__ctas{display:flex;gap:10px;flex-wrap:wrap}
.np__btn{
  display:inline-flex;align-items:center;justify-content:center;
  gap:8px;
  padding:14px 28px;
  border-radius:{{ section.settings.btn_radius }}px;
  font-size:15px;font-weight:700;
  text-decoration:none;white-space:nowrap;
  transition:transform .2s ease,box-shadow .2s ease,background .2s ease;
}
.np__btn:hover{transform:translateY(-2px)}
.np__btn--p{
  background:var(--np-btn-bg);color:var(--np-btn-txt);border:2px solid var(--np-btn-bg);
}
.np__btn--p:hover{box-shadow:0 10px 28px color-mix(in srgb,var(--np-btn-bg) 30%,transparent)}
.np__btn--s{
  background:transparent;color:var(--np-btn2-txt);border:2px solid var(--np-btn2-border);
}
.np__btn--s:hover{background:color-mix(in srgb,var(--np-btn2-border) 6%,transparent)}
.np__btn-ico{width:18px;height:18px;flex-shrink:0}

/* ── Urgency ── */
.np__urgency{
  display:inline-flex;
  align-items:center;
  gap:8px;
  width:fit-content;
  margin:0;
  padding:6px 16px;
  border-radius:999px;
  background:color-mix(in srgb,#ef4444 8%,transparent);
  font-size:13px;
  font-weight:600;
  color:#dc2626;
}
.np__urgency-dot{
  width:8px;height:8px;
  border-radius:50%;
  background:#ef4444;
  animation:np-pulse 1.5s ease-in-out infinite;
}
@keyframes np-pulse{
  0%,100%{opacity:1;transform:scale(1)}
  50%{opacity:.4;transform:scale(.7)}
}

/* ── Scroll-reveal ── */
.np__reveal{
  opacity:0;
  transform:translateY(20px);
  transition:opacity .55s ease,transform .55s ease;
}
.np__reveal--visible{opacity:1;transform:translateY(0)}
.np__info-col .np__reveal:nth-child(1){transition-delay:.05s}
.np__info-col .np__reveal:nth-child(2){transition-delay:.1s}
.np__info-col .np__reveal:nth-child(3){transition-delay:.15s}
.np__info-col .np__reveal:nth-child(4){transition-delay:.2s}
.np__info-col .np__reveal:nth-child(5){transition-delay:.25s}
.np__info-col .np__reveal:nth-child(6){transition-delay:.3s}
.np__info-col .np__reveal:nth-child(7){transition-delay:.35s}
.np__info-col .np__reveal:nth-child(8){transition-delay:.4s}
.np__info-col .np__reveal:nth-child(9){transition-delay:.45s}

/* ── Tablet ── */
@media(max-width:991px) and (min-width:768px){
  .np__grid{gap:32px}
  .np__img-col{flex:0 0 42%;max-width:42%}
  .np__studio{padding:24px 16px;border-radius:1.5rem}
  .np__heading{font-size:clamp(1.5rem,3.2vw,{{ section.settings.heading_size | minus: 6 }}px)}
}

/* ── Mobile ── */
@media(max-width:767px){
  .np{padding:{{ section.settings.padding_top | divided_by: 2 }}px 0 {{ section.settings.padding_bottom | divided_by: 2 }}px}
  .np__grid{flex-direction:column!important;gap:28px}
  .np__img-col{flex:none;max-width:none;width:100%}
  .np__studio{
    max-width:360px;
    margin:0 auto;
    padding:24px 16px;
    border-radius:1.5rem;
  }
  .np__heading{
    font-size:clamp(1.5rem,6.5vw,{{ section.settings.heading_size_mobile }}px);
    line-height:1.12;
  }
  .np__desc{font-size:15px}
  .np__variants-row{width:100%}
  .np__var{flex:1;min-width:70px;padding:12px 12px 10px}
  .np__price{font-size:{{ section.settings.price_size | minus: 6 }}px}
  .np__ctas{width:100%}
  .np__btn{flex:1;text-align:center;padding:14px 20px}
  .np__trust{gap:14px}
  .np__trust-item{font-size:12px}
  .np__coverage{font-size:11px;padding:6px 14px}
  .np__reveal{opacity:1;transform:none;transition:none}
}
</style>

<script>
(function(){
  function initNP(){
    var sec=document.getElementById('np-{{ s_id }}');
    if(!sec)return;

    var priceEl=sec.querySelector('[data-np-price]');
    var compareEl=sec.querySelector('[data-np-compare]');
    var coverageWrap=sec.querySelector('[data-np-coverage]');
    var coverageTxt=coverageWrap?coverageWrap.querySelector('.np__coverage-txt'):null;
    var defaultFrame=sec.querySelector('.np__img-frame--default');
    var btns=sec.querySelectorAll('.np__var');

    btns.forEach(function(btn){
      btn.addEventListener('click',function(){
        sec.querySelectorAll('.np__var--active').forEach(function(el){el.classList.remove('np__var--active')});
        btn.classList.add('np__var--active');

        var price=btn.getAttribute('data-price');
        var compare=btn.getAttribute('data-compare');
        var coverage=btn.getAttribute('data-coverage');
        var vid=btn.getAttribute('data-vid');
        var hasImg=btn.getAttribute('data-has-img')==='1';

        if(priceEl&&price)priceEl.textContent=price;

        if(compareEl){
          if(compare){compareEl.textContent=compare;compareEl.style.display=''}
          else{compareEl.style.display='none'}
        }

        if(coverageTxt){
          if(coverage){coverageTxt.textContent=coverage;if(coverageWrap)coverageWrap.style.opacity='1'}
          else{if(coverageWrap)coverageWrap.style.opacity='0'}
        }

        sec.querySelectorAll('.np__img-frame--active').forEach(function(f){f.classList.remove('np__img-frame--active')});
        var targetFrame=hasImg?sec.querySelector('[data-variant-img="'+vid+'"]'):null;
        if(targetFrame){targetFrame.classList.add('np__img-frame--active')}
        else if(defaultFrame){defaultFrame.classList.add('np__img-frame--active')}
      });
    });

    if('IntersectionObserver' in window){
      var io=new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if(e.isIntersecting){e.target.classList.add('np__reveal--visible');io.unobserve(e.target)}
        });
      },{threshold:0.12,rootMargin:'0px 0px -30px 0px'});
      sec.querySelectorAll('.np__reveal').forEach(function(el){io.observe(el)});
    }else{
      sec.querySelectorAll('.np__reveal').forEach(function(el){el.classList.add('np__reveal--visible')});
    }
  }

  if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',initNP)}else{initNP()}
  document.addEventListener('shopify:section:load',function(e){if(e.target.querySelector('#np-{{ s_id }}'))initNP()});
})();
</script>

