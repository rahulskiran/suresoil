
<div
  id="HeroBanner-{{ section.id }}"
  class="hero-banner color-{{ section.settings.color_scheme }}"
  style="
    --hero-banner-min-height: {{ section.settings.section_height }}svh;
    --hero-banner-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --hero-banner-content-align: {{ section.settings.content_alignment }};
    --hero-banner-text-align: {{ section.settings.text_alignment }};
  "
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  {%- if section.settings.image != blank -%}
    <div class="hero-banner__media">
      {{
        section.settings.image
        | image_url: width: 2000
        | image_tag:
          width: section.settings.image.width,
          widths: '375, 550, 750, 1100, 1500, 1780, 2000',
          height: section.settings.image.height,
          alt: section.settings.image.alt | escape,
          class: 'hero-banner__image',
          loading: 'eager',
          fetchpriority: 'high'
      }}
    </div>
    <div class="hero-banner__overlay"></div>
  {%- else -%}
    <div class="hero-banner__media hero-banner__media--placeholder">
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero-banner__image' }}
    </div>
    <div class="hero-banner__overlay"></div>
  {%- endif -%}

  <div class="hero-banner__content-wrapper page-width">
    <div class="hero-banner__content">
      {%- if section.settings.subheading != blank -%}
        <p class="hero-banner__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }} class="hero-banner__heading">
          {{ section.settings.heading | escape }}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="hero-banner__text rte">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <div class="hero-banner__buttons">
          <a
            href="{{ section.settings.button_link | default: '#' }}"
            class="button button--{{ section.settings.button_style }}"
          >
            {{ section.settings.button_label | escape }}
          </a>

          {%- if section.settings.button_label_2 != blank -%}
            <a
              href="{{ section.settings.button_link_2 | default: '#' }}"
              class="button button--{{ section.settings.button_style_2 }}"
            >
              {{ section.settings.button_label_2 | escape }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .hero-banner {
    position: relative;
    display: flex;
    align-items: var(--hero-banner-content-align, center);
    min-height: var(--hero-banner-min-height, 60svh);
    overflow: hidden;
  }

  .hero-banner__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero-banner__media--placeholder svg {
    width: 100%;
    height: 100%;
  }

  .hero-banner__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgb(0 0 0 / var(--hero-banner-overlay-opacity, 0));
  }

  .hero-banner__content-wrapper {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: 6rem;
    padding-bottom: 6rem;
  }

  .hero-banner__content {
    max-width: 60rem;
    text-align: var(--hero-banner-text-align, left);
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  .hero-banner__subheading {
    font-size: 1.4rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }

  .hero-banner__heading {
    margin: 0;
  }

  .hero-banner__text {
    margin: 0;
  }

  .hero-banner__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    margin-top: 0.8rem;
  }

  @media screen and (max-width: 749px) {
    .hero-banner__content-wrapper {
      padding-top: 4rem;
      padding-bottom: 4rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 20
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "svh",
      "default": 70
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Vertical content alignment",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Middle" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hero banner heading"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Primary button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "tertiary", "label": "Tertiary" }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Secondary button"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style_2",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "tertiary", "label": "Tertiary" }
      ],
      "default": "secondary"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
