{% comment %}Organic Farming Hero — sections/organic-farming-hero.liquid{% endcomment %}

{%- liquid
  assign pt_d  = section.settings.padding_top_desktop
  assign pb_d  = section.settings.padding_bottom_desktop
  assign ph_d  = section.settings.padding_horizontal_desktop
  assign pt_m  = section.settings.padding_top_mobile
  assign pb_m  = section.settings.padding_bottom_mobile
  assign ph_m  = section.settings.padding_horizontal_mobile
  assign s_id  = section.id
-%}

<section class="ah" id="ah-{{ s_id }}">

  {%- unless section.settings.bg_transparent -%}
    <div class="ah__ov" aria-hidden="true"></div>
  {%- endunless -%}

  {%- if section.settings.bg_image != blank -%}
    <div class="ah__bg" aria-hidden="true">
      {{- section.settings.bg_image
          | image_url: width: 1920
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            widths: '640,768,1024,1280,1440,1920',
            sizes: '100vw',
            class: 'ah__img',
            alt: section.settings.bg_image.alt
      -}}
    </div>
  {%- else -%}
    <div class="ah__bg ah__bg--ph" aria-hidden="true">
      {{- 'lifestyle-1' | placeholder_svg_tag: 'ah__img ah__img--svg' -}}
    </div>
  {%- endif -%}

  <div class="ah__grid">
    <div class="ah__wrap">
      {%- if section.settings.badge_text != blank -%}
        <div class="ah__badge" style="--d:0s">
          <span>{{ section.settings.badge_text }}</span>
        </div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="ah__h1" style="--d:.15s">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="ah__sub" style="--d:.3s">{{ section.settings.subtext }}</p>
      {%- endif -%}

      {%- if section.settings.btn_primary_label != blank or section.settings.btn_secondary_label != blank -%}
        <div class="ah__ctas" style="--d:.45s">
          {%- if section.settings.btn_primary_label != blank -%}
            <a href="{{ section.settings.btn_primary_url }}" class="ah__btn ah__btn--p">
              {{- section.settings.btn_primary_label -}}
              {%- if section.settings.show_btn_icons -%}
                <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8l4 4-4 4M8 12h8"/></svg>
              {%- endif -%}
            </a>
          {%- endif -%}
          {%- if section.settings.btn_secondary_label != blank -%}
            <a href="{{ section.settings.btn_secondary_url }}" class="ah__btn ah__btn--s">
              {{- section.settings.btn_secondary_label -}}
              {%- if section.settings.show_btn_icons -%}
                <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8l4 4-4 4M8 12h8"/></svg>
              {%- endif -%}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.portrait_image != blank -%}
      <div class="ah__portrait" style="--d:.6s">
        {{- section.settings.portrait_image
            | image_url: width: 800
            | image_tag:
              loading: 'eager',
              widths: '400,520,640,800',
              sizes: '(max-width: 767px) 0px, 40vw',
              class: 'ah__pimg',
              alt: section.settings.portrait_image.alt
        -}}
      </div>
    {%- endif -%}
  </div>

</section>

<style>
#ah-{{ s_id }}{
  --cp:{{ section.settings.btn_primary_color }};
  --cs:{{ section.settings.btn_secondary_color }};
  --ch:{{ section.settings.heading_color }};
  --cx:{{ section.settings.subtext_color }};
  --cb:{{ section.settings.badge_text_color }};
  --cbb:{{ section.settings.badge_border_color }};
  --cpt:{{ section.settings.btn_primary_text_color }};
  --oc:{{ section.settings.overlay_color }};
  --oo:{{ section.settings.overlay_opacity | divided_by: 100.0 }};
  --od:{{ section.settings.overlay_direction }}deg;
  --br:{{ section.settings.btn_border_radius }}px;
  --bw:{{ section.settings.btn_border_width }}px;
  --bpv:{{ section.settings.btn_padding_v }}px;
  --bph:{{ section.settings.btn_padding_h }}px;
  --fw:{{ section.settings.btn_font_weight }};
  --gap:{{ section.settings.content_gap }}px;
  --bgap:{{ section.settings.btn_gap }}px;
  --smw:{{ section.settings.subtext_max_width }}px;
  --cmw:{{ section.settings.content_max_width }}px;
  --hfs:{{ section.settings.heading_font_size_desktop }}px;
  --xfs:{{ section.settings.subtext_font_size_desktop }}px;
  --bfs:{{ section.settings.badge_font_size_desktop }}px;
  --tfs:{{ section.settings.btn_font_size_desktop }}px;
  --hlh:{{ section.settings.heading_line_height | divided_by: 100.0 }};
  --hls:{{ section.settings.heading_letter_spacing | divided_by: 1000.0 }}em;
  --xlh:{{ section.settings.subtext_line_height | divided_by: 100.0 }};
  --bls:{{ section.settings.badge_letter_spacing | divided_by: 1000.0 }}em;
  --bbw:{{ section.settings.badge_border_width }}px;
  --bpvp:{{ section.settings.badge_padding_v }}px;
  --bphp:{{ section.settings.badge_padding_h }}px;
  --ggap:{{ section.settings.grid_gap }}px;
  --pw:{{ section.settings.portrait_max_width }}%;
  --pir:{{ section.settings.portrait_border_radius }}px;
}

/* ── Section shell ── */
.ah{
  position:relative;
  width:100%;
  overflow:hidden;
  display:flex;
  align-items:{{ section.settings.vertical_alignment }};
  background:{% if section.settings.bg_transparent %}transparent{% else %}{{ section.settings.section_bg_color }}{% endif %};
  {%- case section.settings.layout_mode -%}
    {%- when 'fullscreen' -%}min-height:100svh;
    {%- when '16-9' -%}aspect-ratio:16/9;min-height:{{ section.settings.section_min_height_mobile }}px;
    {%- when '21-9' -%}aspect-ratio:21/9;min-height:{{ section.settings.section_min_height_mobile }}px;
    {%- when '4-5' -%}aspect-ratio:4/5;
    {%- when '1-1' -%}aspect-ratio:1/1;
    {%- else -%}min-height:{{ section.settings.section_min_height }}px;
  {%- endcase -%}
}

/* ── Background ── */
.ah__bg{position:absolute;inset:0;z-index:0}
.ah__img{width:100%;height:100%;object-fit:cover;object-position:{{ section.settings.image_focal_point }};display:block;will-change:transform}
.ah__img--svg{opacity:.3}
{%- if section.settings.enable_kenburns -%}
.ah__img{animation:ah-zoom {{ section.settings.kenburns_duration }}s ease-in-out forwards}
@keyframes ah-zoom{from{transform:scale(1.05)}to{transform:scale(1)}}
{%- endif -%}

/* ── Overlay ── */
{%- unless section.settings.bg_transparent -%}
.ah__ov{position:absolute;inset:0;z-index:1;background:linear-gradient(var(--od),color-mix(in srgb,var(--oc) calc(var(--oo)*100%),transparent) 0%,color-mix(in srgb,var(--oc) calc(var(--oo)*68%),transparent) 52%,color-mix(in srgb,var(--oc) 10%,transparent) 100%)}
{%- endunless -%}

/* ── Grain ── */
{%- if section.settings.enable_grain -%}
.ah::after{content:'';position:absolute;inset:0;z-index:2;opacity:{{ section.settings.grain_opacity | divided_by: 100.0 }};pointer-events:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-size:160px 160px}
{%- endif -%}

/* ── Grid container ── */
.ah__grid{
  position:relative;
  z-index:3;
  width:100%;
  padding:{{ pt_d }}px {{ ph_d }}px {{ pb_d }}px;
  display:flex;
  align-items:center;
  gap:var(--ggap);
  {%- if section.settings.desktop_content_side == 'right' -%}flex-direction:row-reverse;{%- endif -%}
}

/* ── Content column ── */
.ah__wrap{
  flex:1;
  min-width:0;
  max-width:var(--cmw);
  display:flex;
  flex-direction:column;
  gap:var(--gap);
  text-align:{{ section.settings.content_alignment }};
  {%- case section.settings.content_alignment -%}
    {%- when 'center' -%}align-items:center;
    {%- when 'right' -%}align-items:flex-end;
    {%- else -%}align-items:flex-start;
  {%- endcase -%}
}

/* ── Portrait image ── */
.ah__portrait{flex:0 0 var(--pw);max-width:var(--pw);overflow:hidden;border-radius:var(--pir)}
.ah__pimg{width:100%;height:auto;aspect-ratio:{{ section.settings.portrait_aspect_ratio }};object-fit:cover;display:block;border-radius:var(--pir)}

/* ── Badge ── */
.ah__badge{display:inline-flex;width:fit-content;border:var(--bbw) solid var(--cbb);border-radius:999px;padding:var(--bpvp) var(--bphp);background:{{ section.settings.badge_bg_color }}}
.ah__badge span{font-family:{{ section.settings.body_font.family }},{{ section.settings.body_font.fallback_families }};font-weight:{{ section.settings.body_font.weight }};font-size:var(--bfs);letter-spacing:var(--bls);color:var(--cb)}

/* ── Heading ── */
.ah__h1{font-family:{{ section.settings.heading_font.family }},{{ section.settings.heading_font.fallback_families }};font-weight:{{ section.settings.heading_font.weight }};font-size:var(--hfs);line-height:var(--hlh);letter-spacing:var(--hls);color:var(--ch);margin:0}

/* ── Subtext ── */
.ah__sub{font-family:{{ section.settings.body_font.family }},{{ section.settings.body_font.fallback_families }};font-weight:{{ section.settings.body_font.weight }};font-size:var(--xfs);line-height:var(--xlh);color:var(--cx);max-width:var(--smw);margin:0}

/* ── CTAs ── */
.ah__ctas{display:flex;flex-wrap:wrap;gap:var(--bgap);align-items:center;
  {%- if section.settings.content_alignment == 'center' -%}justify-content:center;{%- endif -%}
  {%- if section.settings.content_alignment == 'right' -%}justify-content:flex-end;{%- endif -%}
}

/* ── Buttons ── */
.ah__btn{display:inline-flex;align-items:center;gap:10px;padding:var(--bpv) var(--bph);border-radius:var(--br);font-family:{{ section.settings.body_font.family }},{{ section.settings.body_font.fallback_families }};font-size:var(--tfs);font-weight:var(--fw);text-decoration:none;white-space:nowrap;border:var(--bw) solid;transition:transform .25s ease,box-shadow .25s ease,background .2s ease}
.ah__btn svg{flex-shrink:0;transition:transform .25s ease}
.ah__btn:hover svg{transform:translateX(3px)}
.ah__btn--p{background:var(--cp);color:var(--cpt);border-color:var(--cp)}
.ah__btn--p:hover{filter:brightness(1.12);transform:translateY(-2px);box-shadow:0 8px 22px color-mix(in srgb,var(--cp) 45%,transparent)}
.ah__btn--s{background:transparent;color:var(--cs);border-color:var(--cs)}
.ah__btn--s:hover{background:color-mix(in srgb,var(--cs) 12%,transparent);transform:translateY(-2px);box-shadow:0 8px 22px color-mix(in srgb,var(--cs) 22%,transparent)}

/* ── Divider ── */
{%- if section.settings.show_bottom_divider -%}
.ah::before{content:'';position:absolute;bottom:0;left:0;width:100%;height:{{ section.settings.divider_height }}px;background:{{ section.settings.divider_color }};z-index:4}
{%- endif -%}

/* ── Animations ── */
{%- if section.settings.enable_animations -%}
.ah__badge,.ah__h1,.ah__sub,.ah__ctas,.ah__portrait{opacity:0;transform:translateY(24px);animation:ah-up .65s ease forwards;animation-delay:var(--d,0s)}
@keyframes ah-up{to{opacity:1;transform:translateY(0)}}
{%- endif -%}

/* ── Mobile ── */
@media(max-width:767px){
  .ah{
    {%- case section.settings.layout_mode -%}
      {%- when 'fullscreen' -%}min-height:100svh;
      {%- when '4-5' -%}aspect-ratio:4/5;
      {%- when '1-1' -%}aspect-ratio:1/1;
      {%- when '16-9' -%}aspect-ratio:unset;min-height:{{ section.settings.section_min_height_mobile }}px;
      {%- when '21-9' -%}aspect-ratio:unset;min-height:{{ section.settings.section_min_height_mobile }}px;
      {%- else -%}min-height:{{ section.settings.section_min_height_mobile }}px;
    {%- endcase -%}
  }
  .ah__grid{padding:{{ pt_m }}px {{ ph_m }}px {{ pb_m }}px;flex-direction:column}
  .ah__portrait{display:none}
  .ah__wrap{max-width:100%}
  .ah__h1{font-size:{{ section.settings.heading_font_size_mobile }}px}
  .ah__sub{font-size:{{ section.settings.subtext_font_size_mobile }}px}
  .ah__badge span{font-size:{{ section.settings.badge_font_size_mobile }}px}
  .ah__btn{font-size:{{ section.settings.btn_font_size_mobile }}px}
  {%- case section.settings.mobile_content_alignment -%}
    {%- when 'center' -%}
    .ah__wrap{align-items:center;text-align:center}
    .ah__ctas{justify-content:center}
    {%- when 'right' -%}
    .ah__wrap{align-items:flex-end;text-align:right}
    .ah__ctas{justify-content:flex-end}
  {%- endcase -%}
  {%- if section.settings.mobile_stack_buttons -%}
  .ah__ctas{flex-direction:column;width:100%}
  .ah__btn{width:100%;justify-content:center}
  {%- endif -%}
}
</style>

{% schema %}
{
  "name": "Agri Hero",
  "tag": "section",
  "class": "agri-hero-section",
  "settings": [

    { "type": "header", "content": "─── Layout Mode ──────────────────" },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Hero Layout",
      "info": "Controls the height and aspect ratio of the section",
      "options": [
        { "value": "fullscreen", "label": "Full Screen (100vh)" },
        { "value": "16-9",       "label": "16:9 Widescreen" },
        { "value": "21-9",       "label": "21:9 Super Wide" },
        { "value": "4-5",        "label": "4:5 Portrait" },
        { "value": "1-1",        "label": "1:1 Square" },
        { "value": "fixed",      "label": "Fixed Height (px)" }
      ],
      "default": "fixed"
    },
    {
      "type": "range",
      "id": "section_min_height",
      "label": "Fixed / Min Height — Desktop (px)",
      "info": "Used when layout is Fixed, or as min-height fallback",
      "min": 300, "max": 1000, "step": 10,
      "default": 700
    },
    {
      "type": "range",
      "id": "section_min_height_mobile",
      "label": "Min Height — Mobile (px)",
      "info": "Applied on mobile for 16:9 and 21:9 layouts",
      "min": 300, "max": 900, "step": 10,
      "default": 520
    },

    { "type": "header", "content": "─── Background ───────────────────" },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image",
      "info": "Recommended: 1920×1080px or larger"
    },
    {
      "type": "select",
      "id": "image_focal_point",
      "label": "Image Focal Point",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top",    "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center",   "label": "Left" },
        { "value": "right center",  "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "checkbox",
      "id": "bg_transparent",
      "label": "Transparent Background (removes overlay + section color)",
      "default": false
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Color",
      "default": "#0d1f0e"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#0a1c0a"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity (%)",
      "min": 0, "max": 100, "step": 5,
      "default": 90
    },
    {
      "type": "range",
      "id": "overlay_direction",
      "label": "Overlay Gradient Angle (°)",
      "min": 0, "max": 360, "step": 5,
      "default": 105
    },
    {
      "type": "checkbox",
      "id": "enable_grain",
      "label": "Enable Grain Texture",
      "default": true
    },
    {
      "type": "range",
      "id": "grain_opacity",
      "label": "Grain Opacity (%)",
      "min": 1, "max": 20, "step": 1,
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "enable_kenburns",
      "label": "Enable Ken Burns Zoom",
      "default": true
    },
    {
      "type": "range",
      "id": "kenburns_duration",
      "label": "Ken Burns Duration (seconds)",
      "min": 6, "max": 30, "step": 1,
      "default": 18
    },

    { "type": "header", "content": "─── Portrait Image ───────────────" },
    {
      "type": "image_picker",
      "id": "portrait_image",
      "label": "Portrait Image",
      "info": "Appears beside the content on desktop. Hidden on mobile. Recommended: 800×1000px or larger"
    },
    {
      "type": "select",
      "id": "portrait_aspect_ratio",
      "label": "Portrait Aspect Ratio",
      "options": [
        { "value": "3/4",  "label": "3:4" },
        { "value": "2/3",  "label": "2:3" },
        { "value": "4/5",  "label": "4:5" },
        { "value": "9/16", "label": "9:16" }
      ],
      "default": "3/4"
    },
    {
      "type": "range",
      "id": "portrait_border_radius",
      "label": "Portrait Border Radius (px)",
      "min": 0, "max": 40, "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "portrait_max_width",
      "label": "Portrait Max Width (%)",
      "min": 20, "max": 60, "step": 5,
      "default": 40,
      "info": "Percentage of the grid width on desktop"
    },

    { "type": "header", "content": "─── Padding — Desktop ────────────" },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top — Desktop (px)",
      "min": 0, "max": 240, "step": 4,
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom — Desktop (px)",
      "min": 0, "max": 240, "step": 4,
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_horizontal_desktop",
      "label": "Padding Horizontal — Desktop (px)",
      "min": 0, "max": 160, "step": 4,
      "default": 80
    },

    { "type": "header", "content": "─── Padding — Mobile ─────────────" },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top — Mobile (px)",
      "min": 0, "max": 160, "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom — Mobile (px)",
      "min": 0, "max": 160, "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "label": "Padding Horizontal — Mobile (px)",
      "min": 0, "max": 80, "step": 4,
      "default": 20
    },

    { "type": "header", "content": "─── Fonts ────────────────────────" },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading Font",
      "default": "assistant_n4"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body / Badge / Button Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "label": "Heading Line Height",
      "min": 80, "max": 200, "step": 5,
      "default": 100,
      "info": "Value ÷ 100 = line-height (e.g. 100 = 1.0)"
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Heading Letter Spacing (×0.001em)",
      "min": -50, "max": 100, "step": 5,
      "default": -20,
      "info": "Value ÷ 1000 = em (e.g. -20 = -0.02em)"
    },
    {
      "type": "range",
      "id": "subtext_line_height",
      "label": "Subtext Line Height",
      "min": 100, "max": 250, "step": 5,
      "default": 165,
      "info": "Value ÷ 100 = line-height (e.g. 165 = 1.65)"
    },
    {
      "type": "range",
      "id": "badge_letter_spacing",
      "label": "Badge Letter Spacing (×0.001em)",
      "min": 0, "max": 200, "step": 5,
      "default": 30,
      "info": "Value ÷ 1000 = em (e.g. 30 = 0.03em)"
    },

    { "type": "header", "content": "─── Font Sizes — Desktop ─────────" },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "label": "Heading — Desktop (px)",
      "min": 28, "max": 120, "step": 2,
      "default": 80
    },
    {
      "type": "range",
      "id": "subtext_font_size_desktop",
      "label": "Subtext — Desktop (px)",
      "min": 12, "max": 32, "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "badge_font_size_desktop",
      "label": "Badge — Desktop (px)",
      "min": 10, "max": 24, "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "btn_font_size_desktop",
      "label": "Button — Desktop (px)",
      "min": 10, "max": 24, "step": 1,
      "default": 15
    },

    { "type": "header", "content": "─── Font Sizes — Mobile ──────────" },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading — Mobile (px)",
      "min": 24, "max": 80, "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "subtext_font_size_mobile",
      "label": "Subtext — Mobile (px)",
      "min": 11, "max": 24, "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "badge_font_size_mobile",
      "label": "Badge — Mobile (px)",
      "min": 10, "max": 20, "step": 1,
      "default": 12
    },
