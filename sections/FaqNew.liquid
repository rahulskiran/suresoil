{% comment %}FAQ Section — sections/FaqNew.liquid{% endcomment %}

{%- liquid
  assign s_id = section.id
  assign faqs = section.blocks | where: 'type', 'faq_item'
-%}

<section class="fq" id="fq-{{ s_id }}">
  <div class="fq__wrap">
    <div class="fq__grid">

      {%- comment -%}── Left: Heading column ──{%- endcomment -%}
      <div class="fq__heading-col">
        <div class="fq__heading-inner fq__reveal">
          {%- if section.settings.eyebrow != blank -%}
            <span class="fq__eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            <h2 class="fq__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}

          {%- if section.settings.subheading != blank -%}
            <p class="fq__sub">{{ section.settings.subheading }}</p>
          {%- endif -%}

          {%- if section.settings.cta_label != blank -%}
            <a href="{{ section.settings.cta_url | default: '#' }}" class="fq__cta">
              <svg class="fq__cta-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              {{ section.settings.cta_label }}
              <svg class="fq__cta-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%}── Right: Accordion column ──{%- endcomment -%}
      <div class="fq__accordion-col">
        {%- for block in faqs -%}
          <div class="fq__item fq__reveal{% if forloop.first %} fq__item--open{% endif %}" {{ block.shopify_attributes }}>
            <button class="fq__btn" type="button" aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}">
              <span class="fq__num">{{ forloop.index | prepend: '00' | slice: -2, 2 }}</span>
              <span class="fq__question">{{ block.settings.question | escape }}</span>
              <span class="fq__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
              </span>
            </button>
            <div class="fq__answer-wrap">
              <div class="fq__answer-inner">
                <p class="fq__answer">{{ block.settings.answer | escape }}</p>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

<style>
#fq-{{ s_id }}{
  --fq-bg:{{ section.settings.bg_color }};
  --fq-heading:{{ section.settings.heading_color }};
  --fq-sub:{{ section.settings.subtext_color }};
  --fq-eyebrow-bg:{{ section.settings.eyebrow_bg }};
  --fq-eyebrow-txt:{{ section.settings.eyebrow_text }};
  --fq-border:{{ section.settings.border_color }};
  --fq-num:{{ section.settings.number_color }};
  --fq-q:{{ section.settings.question_color }};
  --fq-a:{{ section.settings.answer_color }};
  --fq-icon:{{ section.settings.icon_color }};
  --fq-active:{{ section.settings.active_color }};
  --fq-cta-bg:{{ section.settings.cta_bg }};
  --fq-cta-txt:{{ section.settings.cta_text }};
  --fq-accent:{{ section.settings.accent_color }};
}

.fq{
  position:relative;
  background:
    radial-gradient(70% 50% at 10% 80%, color-mix(in srgb,var(--fq-accent) 5%,transparent) 0%, transparent 100%),
    radial-gradient(60% 40% at 90% 20%, color-mix(in srgb,var(--fq-active) 4%,transparent) 0%, transparent 100%),
    var(--fq-bg);
  padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  overflow:hidden;
}

.fq__wrap{
  max-width:1200px;
  margin:0 auto;
  padding:0 {{ section.settings.padding_h }}px;
}

.fq__grid{
  display:flex;
  gap:{{ section.settings.grid_gap }}px;
  align-items:flex-start;
}

/* ── Heading column ── */
.fq__heading-col{
  flex:0 0 38%;
  max-width:38%;
  position:sticky;
  top:100px;
}

.fq__heading-inner{
  display:flex;
  flex-direction:column;
  gap:{{ section.settings.heading_gap }}px;
}

.fq__eyebrow{
  display:inline-flex;
  align-items:center;
  gap:6px;
  width:fit-content;
  padding:5px 14px;
  border-radius:999px;
  background:var(--fq-eyebrow-bg);
  color:var(--fq-eyebrow-txt);
  font-size:11px;
  font-weight:600;
  letter-spacing:.12em;
  text-transform:uppercase;
  line-height:1;
}

.fq__heading{
  font-size:clamp(1.75rem,3.8vw,{{ section.settings.heading_size }}px);
  font-weight:800;
  line-height:1.1;
  letter-spacing:-.03em;
  color:var(--fq-heading);
  margin:0;
  max-width:16ch;
  text-wrap:balance;
}

.fq__sub{
  font-size:{{ section.settings.sub_size }}px;
  line-height:1.65;
  color:var(--fq-sub);
  margin:0;
  max-width:36ch;
  text-wrap:pretty;
}

.fq__cta{
  display:inline-flex;
  align-items:center;
  gap:10px;
  padding:12px 24px;
  border-radius:12px;
  background:var(--fq-cta-bg);
  color:var(--fq-cta-txt);
  font-size:14px;
  font-weight:700;
  text-decoration:none;
  white-space:nowrap;
  margin-top:8px;
  transition:transform .25s ease,box-shadow .25s ease;
}
.fq__cta:hover{
  transform:translateY(-2px);
  box-shadow:0 10px 28px color-mix(in srgb,var(--fq-cta-bg) 30%,transparent);
}
.fq__cta-ico{width:18px;height:18px;flex-shrink:0;opacity:.8}
.fq__cta-arrow{width:16px;height:16px;flex-shrink:0;transition:transform .25s ease}
.fq__cta:hover .fq__cta-arrow{transform:translateX(3px)}

/* ── Accordion column ── */
.fq__accordion-col{
  flex:1;
  min-width:0;
  display:flex;
  flex-direction:column;
}

.fq__item{
  border-bottom:1px solid var(--fq-border);
}
.fq__item:first-child{
  border-top:1px solid var(--fq-border);
}

.fq__btn{
  width:100%;
  display:flex;
  align-items:center;
  gap:16px;
  text-align:left;
  padding:22px 0;
  background:none;
  border:none;
  cursor:pointer;
  font-family:inherit;
  transition:padding .3s ease;
}

.fq__num{
  flex-shrink:0;
  font-size:13px;
  font-weight:700;
  font-variant-numeric:tabular-nums;
  color:var(--fq-num);
  opacity:.5;
  min-width:24px;
  transition:color .3s ease,opacity .3s ease;
}

.fq__question{
  flex:1;
  font-size:{{ section.settings.question_size }}px;
  font-weight:600;
  color:var(--fq-q);
  line-height:1.35;
  transition:color .3s ease;
}

.fq__icon{
  flex-shrink:0;
  width:32px;
  height:32px;
  border-radius:8px;
  border:1px solid var(--fq-border);
  display:flex;
  align-items:center;
  justify-content:center;
  color:var(--fq-icon);
  transition:all .35s ease;
}
.fq__icon svg{
  width:16px;
  height:16px;
  transition:transform .35s ease;
}

.fq__btn:hover .fq__question{color:var(--fq-active)}
.fq__btn:hover .fq__num{color:var(--fq-active);opacity:.7}
.fq__btn:hover .fq__icon{
  border-color:color-mix(in srgb,var(--fq-active) 40%,var(--fq-border));
  background:color-mix(in srgb,var(--fq-active) 6%,transparent);
}

/* Open state */
.fq__item--open .fq__num{color:var(--fq-active);opacity:1}
.fq__item--open .fq__question{color:var(--fq-active)}
.fq__item--open .fq__icon{
  background:var(--fq-active);
  border-color:var(--fq-active);
  color:#fff;
}
.fq__item--open .fq__icon svg{transform:rotate(45deg)}

/* Answer animation — CSS grid for smooth auto-height */
.fq__answer-wrap{
  display:grid;
  grid-template-rows:0fr;
  opacity:0;
  transition:grid-template-rows .4s ease,opacity .35s ease;
}

.fq__item--open .fq__answer-wrap{
  grid-template-rows:1fr;
  opacity:1;
}

.fq__answer-inner{
  overflow:hidden;
}

.fq__answer{
  color:var(--fq-a);
  line-height:1.7;
  font-size:{{ section.settings.answer_size }}px;
  font-weight:400;
  padding:0 48px 24px 40px;
  margin:0;
}

/* ── Scroll reveal ── */
.fq__reveal{
  opacity:0;
  transform:translateY(24px);
  transition:opacity .6s ease,transform .6s ease;
}
.fq__revealed{opacity:1;transform:translateY(0)}
.fq__accordion-col .fq__reveal:nth-child(1){transition-delay:.08s}
.fq__accordion-col .fq__reveal:nth-child(2){transition-delay:.14s}
.fq__accordion-col .fq__reveal:nth-child(3){transition-delay:.2s}
.fq__accordion-col .fq__reveal:nth-child(4){transition-delay:.26s}
.fq__accordion-col .fq__reveal:nth-child(5){transition-delay:.32s}
.fq__accordion-col .fq__reveal:nth-child(6){transition-delay:.38s}
.fq__accordion-col .fq__reveal:nth-child(7){transition-delay:.44s}
.fq__accordion-col .fq__reveal:nth-child(8){transition-delay:.5s}

/* ── Tablet ── */
@media(max-width:991px) and (min-width:768px){
  .fq__grid{gap:32px}
  .fq__heading-col{flex:0 0 34%;max-width:34%}
  .fq__heading{font-size:clamp(1.5rem,3.2vw,{{ section.settings.heading_size | minus: 6 }}px)}
  .fq__question{font-size:{{ section.settings.question_size | minus: 1 }}px}
}

/* ── Mobile ── */
@media(max-width:767px){
  .fq{padding:{{ section.settings.padding_top | divided_by: 2 }}px 0 {{ section.settings.padding_bottom | divided_by: 2 }}px}
  .fq__grid{
    flex-direction:column;
    gap:32px;
  }
  .fq__heading-col{
    flex:none;
    max-width:none;
    width:100%;
    position:static;
    text-align:center;
  }
  .fq__heading-inner{align-items:center}
  .fq__heading{
    font-size:clamp(1.5rem,6.5vw,{{ section.settings.heading_size_mobile }}px);
    max-width:none;
    text-align:center;
  }
  .fq__sub{
    font-size:15px;
    max-width:none;
    text-align:center;
  }
  .fq__btn{padding:18px 0;gap:12px}
  .fq__num{font-size:12px;min-width:20px}
  .fq__question{font-size:15px}
  .fq__answer{
    font-size:14px;
    padding:0 32px 20px 32px;
  }
  .fq__icon{width:28px;height:28px;border-radius:6px}
  .fq__icon svg{width:14px;height:14px}
  .fq__reveal{opacity:1;transform:none;transition:none}
}
</style>

<script>
(function(){
  function initFQ(){
    var sec=document.getElementById('fq-{{ s_id }}');
    if(!sec)return;

    var items=sec.querySelectorAll('.fq__item');

    items.forEach(function(item){
      var btn=item.querySelector('.fq__btn');
      btn.addEventListener('click',function(){
        var isOpen=item.classList.contains('fq__item--open');

        items.forEach(function(other){
          other.classList.remove('fq__item--open');
          other.querySelector('.fq__btn').setAttribute('aria-expanded','false');
        });

        if(!isOpen){
          item.classList.add('fq__item--open');
          btn.setAttribute('aria-expanded','true');
        }
      });
    });

    if('IntersectionObserver' in window){
      var io=new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if(e.isIntersecting){e.target.classList.add('fq__revealed');io.unobserve(e.target)}
        });
      },{threshold:0.12,rootMargin:'0px 0px -40px 0px'});
      sec.querySelectorAll('.fq__reveal').forEach(function(el){io.observe(el)});
    }else{
      sec.querySelectorAll('.fq__reveal').forEach(function(el){el.classList.add('fq__revealed')});
    }
  }

  if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',initFQ)}else{initFQ()}
  document.addEventListener('shopify:section:load',function(e){if(e.target.querySelector('#fq-{{ s_id }}'))initFQ()});
})();
</script>

